@inherits LayoutComponentBase
@using blazor_frontend.Services
@inject IChatService ChatService
@inject IJSRuntime JS

<div class="flex h-screen bg-gray-100 overflow-hidden">
    <!-- Sidebar  -->
    <aside class="h-full shadow-lg z-20 transition-all duration-300 ease-in-out shrink-0" style="width: @(_drawerOpen ? "256px" : "0px"); overflow: hidden;">
        <div style="width: 256px; height: 100%;">
            <StaffSidebar Role="Staff" />
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col min-w-0 h-screen transition-all duration-300 ease-in-out">
        <!-- Header -->
        <StaffHeader OnToggleSidebar="DrawerToggle" Role="Staff" 
            StaffName="@_staffName" 
            AvatarUrl="@(_avatarUrl)" />

        <!-- Main Body -->
        <main class="flex-1 p-6 overflow-y-auto">
            @Body
        </main>
    </div>
</div>

@code {
    bool _drawerOpen = true;
    string _staffName = "Nhân viên";
    string _avatarUrl = "https://ui-avatars.com/api/?name=Staff&background=e0f2fe&color=2563eb&size=100";

    protected override async Task OnInitializedAsync()
    {
        var name = await JS.InvokeAsync<string?>("localStorage.getItem", "auth_ho_ten");
        var staffId = await JS.InvokeAsync<string?>("localStorage.getItem", "auth_user_id");
        
        if (!string.IsNullOrEmpty(name))
        {
            _staffName = name;
            _avatarUrl = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(name)}&background=e0f2fe&color=2563eb&size=100";
        }

        if (!string.IsNullOrEmpty(staffId))
        {
            // Tự động đăng ký với ChatHub ngay khi vào bất kỳ trang nào của Staff
            await ChatService.RegisterStaffAsync(staffId, _staffName);
        }
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
