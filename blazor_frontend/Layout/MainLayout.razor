@inherits LayoutComponentBase
@using blazor_frontend.Shared
@inject NavigationManager Nav

<div class="min-h-screen bg-gray-50 flex flex-col">
    <LandingHeader CartCount="0" />

    @if (!IsCartPage)
    {
        <Hero ImagePath="hero22.png" />
    }

    <main class="flex-1 container mx-auto px-4 py-8">
        @Body
    </main>

    <LandingFooter />

    @if (AuthState?.Role != "Admin" && AuthState?.Role != "Staff")
    {
        <ChatWidget />
    }
</div>

@code {
    [Inject] private blazor_frontend.Services.AuthState AuthState { get; set; } = default!;
    private bool IsCartPage =>
        Nav.ToBaseRelativePath(Nav.Uri).StartsWith("cart", StringComparison.OrdinalIgnoreCase);
}