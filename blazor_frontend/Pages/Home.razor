@page "/"
@using blazor_frontend.Shared
@inject blazor_frontend.Services.IProductService productService

@code {
    private List<ProductList.ProductDto> featured = new();

    protected override async Task OnInitializedAsync()
    {
        var products = await productService.GetAllAsync();
        featured = products
            .Take(6)
            .Select(sp =>
            {
                var firstDetail = sp.ChiTietSanPhams.FirstOrDefault();
                var colors = sp.ChiTietSanPhams
                    .Select(x => x.Mau)
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToArray();

                return new ProductList.ProductDto(
                    Id: sp.MaSP.ToString(),
                    ImagePath: firstDetail?.Anh ?? "product1.jpg",
                    Title: sp.TenSP,
                    Price: $"{(firstDetail?.Gia ?? 0):n0}₫",
                    BadgeText: "HÀNG MỚI",
                    Colors: colors.Length > 0 ? colors : ["#000000"],
                    CategoryId: sp.MaDM);
            })
            .ToList();
    }
}

<div class="max-w-[1200px] mx-auto px-4 md:px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">
        <!-- Left promo banner (tall) -->
        <div class="lg:col-span-1">
            <PromoBanner ImagePath="/hero.png" Title="ĐỒ CÔNG SỞ" CtaText="XEM NGAY" Link="/products" />
        </div>

        <!-- Right: product grid (3 columns) -->
        <div class="lg:col-span-3">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800">Đồ Công Sở</h2>
                <nav class="text-sm text-gray-500">
                    <a class="mr-6">Hàng mới</a>
                    <a class="mr-6">Set đồ</a>
                </nav>
            </div>

            <ProductList Items="featured" ShowActions="true" />
        </div>
    </div>
</div>
