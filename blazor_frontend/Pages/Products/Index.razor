@page "/products"
@using System.Globalization
@using blazor_frontend.Shared
@inject blazor_frontend.Services.IProductService productService
@inject blazor_frontend.Services.ICategoryService categoryService

<div class="bg-gray-50 pb-12 min-h-screen">
    <!-- Breadcrumb -->
    <div class="bg-white border-b border-gray-100">
        <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-3">
            <nav class="text-xs text-gray-500 font-medium">
                <a href="/" class="text-blue-600 hover:underline transition-colors">Trang chủ</a>
                <span class="mx-2 text-gray-400">/</span>
                <a href="#" class="text-blue-600 hover:underline transition-colors">Danh mục</a>
                <span class="mx-2 text-gray-400">/</span>
                <span class="text-gray-800">Tất cả sản phẩm</span>
            </nav>
        </div>
    </div>

    <!-- Category Banner -->
    <div class="bg-[#E9F0FA] relative overflow-hidden mb-8 shadow-sm">
        <div class="max-w-[1200px] mx-auto px-4 md:px-6 flex items-center min-h-[350px]">
            <div class="w-1/2 relative z-10">
                <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-[#002855] tracking-tighter whitespace-nowrap mb-2">TẤT CẢ SẢN PHẨM</h1>
                <p class="text-2xl md:text-3xl text-[#004bb8] font-medium tracking-[0.2em] uppercase pl-1">ALL ITEMS</p>
                <div class="mt-8 hidden md:block">
                    <svg class="text-[#002855] opacity-10 w-64 h-64 absolute -left-12 -top-12 z-[-1]" viewBox="0 0 100 100" fill="currentColor">
                        <path d="M10 10h80v80H10z" stroke="currentColor" stroke-width="4" fill="none"/>
                        <!-- Decorative element -->
                        <path d="M30 30h40v40H30z" fill="currentColor"/>
                    </svg>
                </div>
            </div>
            <div class="w-1/2 absolute right-0 top-0 bottom-0">
                <!-- Fallbacks if hero.png not found -->
                <img src="hero.png" alt="Tất Cả Sản Phẩm" class="w-full h-full object-cover object-top" onerror="this.src='product1.jpg';this.onerror='';" />
            </div>
        </div>
    </div>

    <!-- Filter Buttons & Tool bar -->
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
            <button class='flex items-center gap-2 px-6 py-2 border @(SelectedCategory == string.Empty ? "border-black" : "border-gray-300") rounded hover:border-black transition-colors bg-white hover:bg-gray-50 font-medium text-sm text-gray-800' @onclick="() => SelectCategory(string.Empty)">
                <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                Tất cả
            </button>
            @foreach (var ldm in AvailableLoaiDanhMucNames)
            {
                <button class='flex items-center gap-2 px-6 py-2 border @(SelectedCategory == ldm ? "border-black" : "border-gray-300") rounded hover:border-black transition-colors bg-white hover:bg-gray-50 font-medium text-sm text-gray-800' @onclick="() => SelectCategory(ldm)">
                    @ldm
                </button>
            }
        </div>

        <div class="flex items-center justify-end mb-6 border-b border-gray-200 pb-4">
            <select class="border border-gray-300 rounded-md px-4 py-2 text-sm bg-white font-medium text-gray-700 outline-none hover:border-black focus:border-black transition-colors focus:ring-1 focus:ring-black cursor-pointer shadow-sm" @bind="SortMode">
                <option>Sản phẩm nổi bật</option>
                <option>Giá: Tăng dần</option>
                <option>Giá: Giảm dần</option>
                <option>Mới nhất</option>
            </select>
        </div>

        <!-- Product Grid -->
        @if (isLoading)
        {
            <div class="py-12 text-center text-gray-500">Đang tải sản phẩm...</div>
        }
        else if (!FilteredProducts.Any())
        {
            <div class="py-12 text-center text-gray-500">Chưa có sản phẩm nào.</div>
        }
        else
        {
            <ProductList Items="FilteredProducts" GridClass="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5" ShowActions="true" />
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private string SelectedCategory = string.Empty;
    private string SortMode = "Sản phẩm nổi bật";
    private Dictionary<Guid, DanhMucDto> danhMucById = new();

    private List<ProductList.ProductDto> allProducts = new();
    private IEnumerable<string> AvailableLoaiDanhMucNames => allProducts
        .Select(p => p.Category)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x);

    private IEnumerable<ProductList.ProductDto> FilteredProducts
    {
        get
        {
            IEnumerable<ProductList.ProductDto> query = allProducts;

            if (!string.IsNullOrWhiteSpace(SelectedCategory))
            {
                query = query.Where(p => p.Category == SelectedCategory);
            }

            query = SortMode switch
            {
                "Giá: Tăng dần" => query.OrderBy(p => ParsePrice(p.Price)),
                "Giá: Giảm dần" => query.OrderByDescending(p => ParsePrice(p.Price)),
                "Mới nhất" => query.OrderByDescending(p => p.Id),
                _ => query
            };

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var danhMucs = (await categoryService.GetAllAsync()).ToList();
        danhMucById = danhMucs.ToDictionary(x => x.MaDM, x => x);

        var products = await productService.GetAllAsync();
        allProducts = products.SelectMany(MapToCards).ToList();
        isLoading = false;
    }

    private void SelectCategory(string category)
    {
        SelectedCategory = category;
    }

    private static decimal ParsePrice(string price)
    {
        var digits = new string(price.Where(char.IsDigit).ToArray());
        return decimal.TryParse(digits, NumberStyles.Number, CultureInfo.InvariantCulture, out var value) ? value : 0;
    }

    private IEnumerable<ProductList.ProductDto> MapToCards(SanPhamDto product)
    {
        var details = product.ChiTietSanPhams ?? [];
        var colors = details
            .Select(x => x.Mau)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        var price = details.FirstOrDefault()?.Gia ?? 0;
        var badgeText = details.Any() ? "HÀNG MỚI" : string.Empty;

        var tenLdm = danhMucById.TryGetValue(product.MaDM, out var dm) ? dm.TenLDM : string.Empty;

        yield return new ProductList.ProductDto(
            Id: product.MaSP.ToString(),
            ImagePath: details.FirstOrDefault()?.Anh ?? "product1.jpg",
            Title: product.TenSP,
            Price: $"{price:n0}₫",
            BadgeText: badgeText,
            Colors: colors.Length > 0 ? colors : ["#000000"],
            Category: tenLdm,
            CategoryId: product.MaDM);
    }
}
