@page "/staff/messages"
@using blazor_frontend.Models
@using blazor_frontend.Services
@inject IChatService ChatService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tư vấn khách hàng</PageTitle>

<div class="p-6 h-[calc(100vh-64px)] overflow-hidden flex flex-col">
    <!-- Chat Container -->
    <div class="flex-1 flex rounded-xl shadow-sm border border-gray-200 overflow-hidden bg-white">
        <!-- Cột trái -->
        <div class="w-full md:w-[320px] lg:w-[350px] border-r border-gray-200 flex flex-col bg-white shrink-0">
            <!-- Header danh sách -->
            <div class="p-4 border-b border-gray-200">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold text-gray-800">Trò chuyện</h2>
                    <button class="p-2 text-gray-500 hover:bg-gray-100 rounded-lg transition" title="Tải lại" @onclick="RefreshConversations">
                        <i class="ph ph-arrows-clockwise text-lg"></i>
                    </button>
                </div>
                <div class="relative">
                    <i class="ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-500"></i>
                    <input type="text" placeholder="Tìm kiếm khách hàng..." @bind="searchTerm" @bind:event="oninput"
                           class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-sm transition-all" />
                </div>
            </div>

            <!-- Danh sách trò chuyện -->
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                @foreach (var chat in FilteredConversations)
                {
                    <div @onclick="() => SelectConversation(chat)" 
                          class="flex items-center gap-3 p-4 border-b border-gray-50 cursor-pointer transition-all @(selectedChat?.Id == chat.Id ? "bg-blue-50/50 border-l-4 border-l-blue-600" : "hover:bg-gray-50 border-l-4 border-l-transparent")">
                        <div class="relative shrink-0">
                            <img src="@(chat.AvatarUrl)" alt="Avatar" class="w-10 h-10 rounded-full object-cover border border-gray-200 @(chat.SessionStatus == "CLOSED" ? "opacity-50 grayscale" : "")" />
                            @if (chat.IsOnline && chat.SessionStatus == "ACTIVE")
                            {
                                <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></span>
                            }
                            else if (chat.SessionStatus == "CLOSED")
                            {
                                <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-gray-400 border-2 border-white rounded-full"></span>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start mb-1">
                                <h4 class="text-sm font-semibold truncate @(chat.SessionStatus == "CLOSED" ? "text-gray-400" : "text-gray-900")">@chat.CustomerName</h4>
                                <div class="flex items-center gap-1.5 ml-2">
                                    @if (chat.SessionStatus == "CLOSED")
                                    {
                                        <span class="text-[10px] font-bold text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">Đã đóng</span>
                                    }
                                    <span class="text-xs text-gray-500 whitespace-nowrap">@chat.LastMessageTime.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            </div>
                            <div class="flex justify-between items-center text-sm">
                                <p class="truncate text-gray-500">
                                    @(chat.LastSender == "Me" ? "Bạn: " : "")@chat.LastMessage
                                </p>
                                @if (chat.UnreadCount > 0)
                                {
                                    <span class="bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full ml-2 min-w-[18px] text-center">@chat.UnreadCount</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Cột phải -->
        <div class="hidden md:flex flex-col flex-1 bg-gray-50 relative">
            @if (selectedChat == null)
            {
                <div class="flex-1 flex flex-col items-center justify-center text-gray-400">
                    <i class="ph ph-chats-circle text-6xl mb-4 text-gray-300"></i>
                    <h3 class="text-lg font-medium text-gray-600">Chưa chọn đoạn chat</h3>
                    <p class="text-sm">Chọn một khách hàng từ danh sách bên trái để phản hồi</p>
                </div>
            }
            else
            {
                <!-- Header Chat -->
                <div class="px-6 py-3 border-b border-gray-200 flex justify-between items-center bg-white shadow-sm z-10 min-h-[64px]">
                    <div class="flex items-center gap-3">
                        <img src="@selectedChat.AvatarUrl" class="w-10 h-10 rounded-full object-cover border border-gray-200" />
                        <div>
                            <h3 class="font-bold text-gray-900 leading-tight text-[15px]">@selectedChat.CustomerName</h3>
                            <div class="flex items-center gap-1.5 mt-0.5">
                                @if (selectedChat.SessionStatus == "ACTIVE")
                                {
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                    <span class="text-xs text-green-600 font-medium">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                                    <span class="text-xs text-gray-500">Phiên đã kết thúc</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        @if (selectedChat.SessionStatus == "ACTIVE")
                        {
                            <button @onclick="CloseCurrentSession" class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 border border-red-200 rounded-lg transition-colors" title="Kết thúc phiên chat">
                                <i class="ph ph-x-circle text-base"></i>
                                Kết thúc
                            </button>
                        }
                        else
                        {
                            <button @onclick="ReopenCurrentSession" class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-green-600 bg-green-50 hover:bg-green-100 border border-green-200 rounded-lg transition-colors" title="Mở lại phiên chat">
                                <i class="ph ph-arrow-counter-clockwise text-base"></i>
                                Mở lại
                            </button>
                        }
                    </div>
                </div>

                <!-- Phần nhắn tin -->
                <div id="staffChatContainer" class="flex-1 overflow-y-auto p-6 flex flex-col gap-4 custom-scrollbar bg-gray-50/50">
                    <div class="text-center">
                        <span class="text-xs font-medium text-gray-500 bg-gray-200/60 px-3 py-1 rounded-full">
                            @selectedChat.LastMessageTime.ToLocalTime().ToString("dd/MM/yyyy")
                        </span>
                    </div>

                    @foreach (var msg in currentMessages)
                    {
                        <div class="flex @(msg.IsMine ? "justify-end" : "justify-start") group items-end gap-2">
                            @if (!msg.IsMine)
                            {
                                <img src="@(string.IsNullOrEmpty(msg.Avatar) ? selectedChat.AvatarUrl : msg.Avatar)" class="w-8 h-8 rounded-full shrink-0 object-cover" />
                            }
                            else 
                            {
                                <img src="@myStaffAvatar" class="w-8 h-8 rounded-full shrink-0 object-cover order-last" />
                            }

                            <div class="max-w-[70%] flex flex-col @(msg.IsMine ? "items-end" : "items-start")">
                                <div class="px-4 py-2.5 shadow-sm text-[15px] @(msg.IsMine ? "bg-blue-600 text-white rounded-lg rounded-br-sm" : "bg-white border border-gray-200 text-gray-800 rounded-lg rounded-bl-sm") leading-relaxed break-words whitespace-pre-wrap">
                                    @msg.Text
                                </div>
                                <span class="text-[11px] text-gray-400 mt-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    @msg.Timestamp.ToLocalTime().ToString("HH:mm")
                                </span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Phần nhập tin nhắn -->
                @if (selectedChat.SessionStatus == "ACTIVE")
                {
                    <div class="p-4 bg-white border-t border-gray-200">
                        <div class="flex items-end gap-3">
                            <div class="flex-1 relative">
                                <textarea @bind="newMessage" @bind:event="oninput" @onkeyup="HandleKeyUp"
                                          placeholder="Trả lời khách hàng..." 
                                          rows="3"
                                          class="w-full block border border-gray-300 rounded-lg px-4 py-2.5 text-[15px] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y min-h-[80px] max-h-[250px] custom-scrollbar"></textarea>
                            </div>
                            <button @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessage)" 
                                    class="bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white px-5 py-2.5 rounded-lg flex items-center gap-2 transition font-medium text-[15px] h-fit">
                                <span>Gửi</span>
                                <i class="ph ph-paper-plane-right"></i>
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-4 bg-gray-100 border-t border-gray-200 text-center">
                        <div class="flex items-center justify-center gap-2 text-gray-500">
                            <i class="ph ph-lock text-lg"></i>
                            <span class="text-sm font-medium">Phiên chat đã kết thúc. Bấm "Mở lại" để tiếp tục tư vấn.</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    /* Styling scrollbar for general look */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }
    .custom-scrollbar:hover::-webkit-scrollbar-thumb {
        background: #94a3b8;
    }
</style>

@code {
    private List<ChatUIModel> conversations = new();
    private ChatUIModel? selectedChat;
    private List<MessageUIModel> currentMessages = new();
    private string newMessage = "";
    private string searchTerm = "";

    private IEnumerable<ChatUIModel> FilteredConversations => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? conversations 
            : conversations.Where(c => c.CustomerName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) 
                                      || c.LastMessage.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
    
    private string myStaffId = ""; 
    private string myStaffAvatar = "";
    private HashSet<Guid> receivedMessageIds = new(); // Chống duplicate tin nhắn
    
    protected override async Task OnInitializedAsync()
    {
        // 0. Lấy ID thật của nhân viên từ Storage
        myStaffId = await JS.InvokeAsync<string>("localStorage.getItem", "auth_user_id") ?? "STAFF_ANON";
        myStaffAvatar = await JS.InvokeAsync<string>("localStorage.getItem", "auth_avatar") ?? "";
        if (string.IsNullOrEmpty(myStaffAvatar)) 
            myStaffAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString("STAFF")}&background=random";
            
        var staffName = await JS.InvokeAsync<string>("localStorage.getItem", "auth_ho_ten") ?? "Tư vấn viên";

        // 1. Đăng ký sự kiện
        ChatService.OnNewChatAssigned += HandleNewChatAssigned;
        ChatService.OnMessageReceived += HandleMessageReceived;
        ChatService.OnSessionClosed += HandleSessionClosed;
        ChatService.OnSessionReopened += HandleSessionReopened;
        ChatService.OnSessionUpgraded += HandleSessionUpgraded;

        // 2. Khởi tạo và Tải danh sách
        await ChatService.InitializeAsync();
        await RefreshConversations();

        // 3. Đăng ký nhân viên này vào hàng chờ (CHỈ NẾU KHÔNG PHẢI ADMIN)
        var userRole = await JS.InvokeAsync<string>("localStorage.getItem", "auth_user_role");
        if (userRole != "ADMIN")
        {
            await ChatService.RegisterStaffAsync(myStaffId, staffName, myStaffAvatar);
        }
    }

    private async Task RefreshConversations()
    {
        try
        {
            var dbSessions = await ChatService.GetAllChatSessionsAsync();
            if (dbSessions != null && dbSessions.Any())
            {
                conversations = dbSessions
                    .OrderByDescending(s => s.LastTime)
                    .Select(s => new ChatUIModel
                    {
                        Id = s.Id.ToString(),
                        CustomerName = !string.IsNullOrEmpty(s.HoTen) ? s.HoTen : (s.ClientType == "GUEST" ? "Khách Vãng Lai" : "Thành viên"),
                        AvatarUrl = !string.IsNullOrEmpty(s.Avatar) ? s.Avatar : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(!string.IsNullOrEmpty(s.HoTen) ? s.HoTen : "Guest")}&background=random",
                        LastMessage = s.LastMessage,
                        LastSender = "N/A",
                        LastMessageTime = s.LastTime,
                        UnreadCount = s.UnreadCount,
                        IsOnline = s.TrangThai == "ACTIVE",
                        SessionStatus = s.TrangThai
                    }).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi không lấy được LS Phien: " + ex.Message);
        }
        StateHasChanged();
    }

    private void HandleNewChatAssigned(ChatSessionDto phien)
    {
        if (conversations.Any(c => c.Id == phien.Id.ToString())) return;

        var newChat = new ChatUIModel
        {
            Id = phien.Id.ToString(),
            CustomerName = phien.ClientType == "GUEST" ? "Khách Vãng Lai" : "Thành viên",
            AvatarUrl = !string.IsNullOrEmpty(phien.Avatar) ? phien.Avatar : $"https://ui-avatars.com/api/?name=Guest&background=random",
            LastMessage = phien.LastMessage,
            LastSender = "System",
            LastMessageTime = phien.LastTime,
            SessionStatus = phien.TrangThai,
            IsOnline = true,
            UnreadCount = phien.UnreadCount
        };

        conversations.Insert(0, newChat);
        InvokeAsync(StateHasChanged);
    }

    private void HandleMessageReceived(blazor_frontend.Models.ChatMessageDto tinNhan)
    {
        if (!receivedMessageIds.Add(tinNhan.ClientID)) return;

        var phienIdStr = tinNhan.MaPhien.ToString();
        var chatRoom = conversations.FirstOrDefault(c => c.Id?.Equals(phienIdStr, StringComparison.OrdinalIgnoreCase) == true);

        if (chatRoom == null)
        {
            chatRoom = new ChatUIModel
            {
                Id = phienIdStr,
                CustomerName = tinNhan.SenderType == "GUEST" ? "Khách Vãng Lai" : "Thành viên",
                AvatarUrl = !string.IsNullOrEmpty(tinNhan.SenderAvatar) ? tinNhan.SenderAvatar : $"https://ui-avatars.com/api/?name={(tinNhan.SenderType == "GUEST" ? "Guest" : "Member")}&background=random",
                UnreadCount = 0,
                SessionStatus = "ACTIVE",
                IsOnline = true
            };
            conversations.Insert(0, chatRoom);
        }

        chatRoom.LastMessage = tinNhan.NoiDung;
        chatRoom.LastSender = tinNhan.SenderType == "STAFF" ? "Me" : "Customer";
        chatRoom.LastMessageTime = tinNhan.ThoiGianGui;

        if (selectedChat != null && selectedChat.Id?.Equals(phienIdStr, StringComparison.OrdinalIgnoreCase) == true)
        {
            if (tinNhan.SenderType != "STAFF") 
            {
                currentMessages.Add(new MessageUIModel 
                {
                    Text = tinNhan.NoiDung,
                    Timestamp = tinNhan.ThoiGianGui,
                    IsMine = false,
                    Avatar = tinNhan.SenderAvatar
                });

                _ = ChatService.MarkAsReadAsync(phienIdStr);
            }
        }
        else if (tinNhan.SenderType != "STAFF")
        {
            chatRoom.UnreadCount++;
        }

        conversations.Remove(chatRoom);
        conversations.Insert(0, chatRoom);

        InvokeAsync(async () => {
            StateHasChanged();
            await Task.Delay(100);
            await ScrollToBottom();
        });
    }

    private void HandleSessionClosed(string maPhien)
    {
        var chat = conversations.FirstOrDefault(c => c.Id?.Equals(maPhien, StringComparison.OrdinalIgnoreCase) == true);
        if (chat != null)
        {
            chat.SessionStatus = "CLOSED";
            chat.IsOnline = false;
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionReopened(string maPhien)
    {
        var chat = conversations.FirstOrDefault(c => c.Id?.Equals(maPhien, StringComparison.OrdinalIgnoreCase) == true);
        if (chat != null)
        {
            chat.SessionStatus = "ACTIVE";
            chat.IsOnline = true;
            conversations.Remove(chat);
            conversations.Insert(0, chat);
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionUpgraded(string maPhien, string hoTen)
    {
        var chat = conversations.FirstOrDefault(c => c.Id?.Equals(maPhien, StringComparison.OrdinalIgnoreCase) == true);
        if (chat != null)
        {
            chat.CustomerName = hoTen;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task SelectConversation(ChatUIModel chat)
    {
        selectedChat = chat;
        chat.UnreadCount = 0;
        currentMessages.Clear();

        await ChatService.MarkAsReadAsync(chat.Id!);

        try
        {
            var dbMsgs = await ChatService.GetChatHistoryAsync(Guid.Parse(chat.Id!));
            if (dbMsgs != null && dbMsgs.Any())
            {
                currentMessages = dbMsgs.OrderBy(m => m.ThoiGianGui)
                    .Select(m => new MessageUIModel
                    {
                        Text = m.NoiDung,
                        Timestamp = m.ThoiGianGui,
                        IsMine = m.SenderType == "STAFF",
                        Avatar = m.SenderAvatar
                    }).ToList();
                
                StateHasChanged();
                await Task.Delay(300);
                await ScrollToBottom();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi tải chi tiết chat: " + ex.Message);
        }

        await ChatService.JoinChatSessionAsync(chat.Id!);
        StateHasChanged();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            if (!string.IsNullOrWhiteSpace(newMessage))
            {
                await SendMessage();
            }
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage) || selectedChat == null) return;

        var textToSend = newMessage.Trim();
        newMessage = "";

        currentMessages.Add(new MessageUIModel { Text = textToSend, Timestamp = DateTime.Now, IsMine = true });
        selectedChat.LastMessage = textToSend;
        selectedChat.LastSender = "Me";
        selectedChat.LastMessageTime = DateTime.Now;

        conversations.Remove(selectedChat);
        conversations.Insert(0, selectedChat);

        StateHasChanged();
        await Task.Delay(50);
        await ScrollToBottom();

        await ChatService.SendMessageAsync(new blazor_frontend.Models.ChatMessageDto
        {
            MaPhien = Guid.Parse(selectedChat.Id!),
            SenderType = "STAFF",
            SenderName = "Nhân viên",
            SenderAvatar = myStaffAvatar,
            NoiDung = textToSend,
            TrangThai = "sent"
        });
    }

    private async Task CloseCurrentSession()
    {
        if (selectedChat == null) return;
        await ChatService.CloseSessionAsync(selectedChat.Id!, myStaffId);
    }

    private async Task ReopenCurrentSession()
    {
        if (selectedChat == null) return;
        await ChatService.ReopenSessionAsync(selectedChat.Id!, myStaffId);
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("scrollToBottomById", "staffChatContainer"); }
        catch { }
    }

    public void Dispose()
    {
        ChatService.OnNewChatAssigned -= HandleNewChatAssigned;
        ChatService.OnMessageReceived -= HandleMessageReceived;
        ChatService.OnSessionClosed -= HandleSessionClosed;
        ChatService.OnSessionReopened -= HandleSessionReopened;
        ChatService.OnSessionUpgraded -= HandleSessionUpgraded;
    }

    // --- MODELS CỦA GIAO DIỆN ---
    public class ChatUIModel
    {
        public string? Id { get; set; }
        public string CustomerName { get; set; } = "";
        public string AvatarUrl { get; set; } = "";
        public string LastMessage { get; set; } = "";
        public string LastSender { get; set; } = "";
        public DateTime LastMessageTime { get; set; }
        public int UnreadCount { get; set; }
        public bool IsOnline { get; set; }
        public string SessionStatus { get; set; } = "ACTIVE";
    }

    public class MessageUIModel
    {
        public string Text { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public bool IsMine { get; set; }
        public string Avatar { get; set; } = "";
    }
}
