@page "/staff/orders"
@page "/account/orders"
@layout blazor_frontend.Layout.AccountProfileLayout
@using System.Linq
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IOrderService orderService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Đơn hàng của tôi</PageTitle>

<div class="max-w-6xl mx-auto px-4 md:px-6 py-6">
    @if (isLoading)
    {
        <div class="rounded-2xl border border-gray-200 bg-white p-8 text-center text-gray-500">
            Đang tải đơn hàng...
        </div>
    }
    else
    {
        <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Đơn hàng của tôi</h1>
                <p class="mt-1 text-sm text-gray-500">Theo dõi trạng thái và chi tiết đơn hàng đã đặt.</p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <div class="grid grid-cols-3 gap-3 text-sm">
                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
                        <div class="text-gray-500">Tổng đơn</div>
                        <div class="mt-1 text-lg font-bold text-gray-900">@orders.Count</div>
                    </div>
                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
                        <div class="text-gray-500">Chờ xác nhận</div>
                        <div class="mt-1 text-lg font-bold text-amber-600">@orders.Count(o => NormalizeStatus(o.TrangThaiDH) == "pending")</div>
                    </div>
                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
                        <div class="text-gray-500">Đã hoàn tất</div>
                        <div class="mt-1 text-lg font-bold text-green-600">@orders.Count(o => NormalizeStatus(o.TrangThaiDH) == "completed")</div>
                    </div>
                </div>

                <button class="inline-flex items-center gap-2 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-600 hover:bg-red-100"
                        @onclick="LogoutAsync">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1" />
                    </svg>
                    Đăng xuất
                </button>
            </div>
        </div>

        @if (!orders.Any())
        {
            <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 text-gray-500">
                    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 6h12l-2-6M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" />
                    </svg>
                </div>
                <h2 class="mt-4 text-xl font-semibold text-gray-900">Chưa có đơn hàng nào</h2>
                <p class="mt-2 text-sm text-gray-500">Hãy mua sắm để tạo đơn hàng đầu tiên.</p>
                <button class="mt-5 rounded-lg border border-gray-300 px-5 py-2.5 font-semibold text-gray-700 hover:bg-gray-50"
                        @onclick="GoShopping">
                    Mua sắm ngay
                </button>
            </div>
        }
        else
        {
            <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
                            <tr>
                                <th class="px-5 py-4 font-semibold">Đơn hàng</th>
                                <th class="px-5 py-4 font-semibold">Ngày đặt</th>
                                <th class="px-5 py-4 font-semibold">Địa chỉ</th>
                                <th class="px-5 py-4 text-right font-semibold">Tổng tiền</th>
                                <th class="px-5 py-4 text-center font-semibold">Trạng thái</th>
                                <th class="px-5 py-4 text-center font-semibold">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var order in orders)
                            {
                                <tr class="hover:bg-gray-50/70">
                                    <td class="px-5 py-4">
                                        <div class="font-semibold text-gray-900">@order.MaDH</div>
                                        <div class="mt-1 text-xs text-gray-500">@order.HoTen • @order.SoDienThoai</div>
                                        <div class="mt-2 text-xs text-gray-500">@GetItemSummary(order)</div>
                                    </td>
                                    <td class="px-5 py-4 text-gray-600">@order.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-5 py-4 text-gray-600">@order.DiaChiGiaoHang</td>
                                    <td class="px-5 py-4 text-right font-semibold text-gray-900">@order.TongTien.ToString("N0")đ</td>
                                    <td class="px-5 py-4 text-center">
                                        <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold @GetStatusClass(order.TrangThaiDH)">
                                            @GetStatusText(order.TrangThaiDH)
                                        </span>
                                    </td>
                                    <td class="px-5 py-4 text-center">
                                        <button class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
                                                @onclick="() => ViewDetail(order.MaDH)">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12H9m12 0c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z" />
                                            </svg>
                                            Xem chi tiết
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

</div>

@code {
    private List<DonHangDto> orders = new();
    private bool isLoading = true;
    private bool isAuthenticated;
    private Guid currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var token = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "auth_token");
        var userIdText = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "auth_user_id");
        isAuthenticated = !string.IsNullOrWhiteSpace(token) && Guid.TryParse(userIdText, out currentUserId);

        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/account/signin?returnUrl=/account/orders");
            isLoading = false;
            return;
        }

        try
        {
            var result = await orderService.GetOrdersByUserIdAsync(currentUserId);
            orders = result.OrderByDescending(x => x.NgayDat).ToList();
        }
        catch
        {
            orders = new List<DonHangDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetail(Guid maDH)
    {
        Navigation.NavigateTo($"/account/orders/{maDH}");
    }

    private void GoToSignIn()
    {
        Navigation.NavigateTo("/account/signin?returnUrl=/account/orders");
    }

    private void GoShopping()
    {
        Navigation.NavigateTo("/products");
    }

    private async Task LogoutAsync()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "auth_token");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "auth_user_id");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "auth_ho_ten");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "auth_role");
        Navigation.NavigateTo("/account/signin");
    }

    private static string GetItemSummary(DonHangDto order)
    {
        if (order.ChiTietDonHangs == null || order.ChiTietDonHangs.Count == 0)
        {
            return "Chưa có sản phẩm";
        }

        var first = order.ChiTietDonHangs[0].TenSP_LuuTru;
        var moreCount = order.ChiTietDonHangs.Count - 1;
        return moreCount > 0 ? $"{first} và {moreCount} sản phẩm khác" : first;
    }

    private static string NormalizeStatus(string? status)
    {
        return status?.Trim().ToLowerInvariant() switch
        {
            "choxacnhan" => "pending",
            "dangxuly" => "processing",
            "danggiao" => "shipping",
            "hoantat" => "completed",
            "dahuy" => "cancelled",
            "pending" => "pending",
            "processing" => "processing",
            "shipping" => "shipping",
            "completed" => "completed",
            "cancelled" => "cancelled",
            _ => "pending"
        };
    }

    private static string GetStatusText(string status)
    {
        return NormalizeStatus(status) switch
        {
            "pending" => "Chờ xác nhận",
            "processing" => "Đang xử lý",
            "shipping" => "Đang giao",
            "completed" => "Hoàn tất",
            "cancelled" => "Đã hủy",
            _ => "Không rõ"
        };
    }

    private static string GetStatusClass(string status)
    {
        return NormalizeStatus(status) switch
        {
            "pending" => "border-amber-200 bg-amber-50 text-amber-700",
            "processing" => "border-blue-200 bg-blue-50 text-blue-700",
            "shipping" => "border-purple-200 bg-purple-50 text-purple-700",
            "completed" => "border-green-200 bg-green-50 text-green-700",
            "cancelled" => "border-red-200 bg-red-50 text-red-700",
            _ => "border-gray-200 bg-gray-50 text-gray-700"
        };
    }
}

