@page "/admin/products"
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IProductService productService
@inject blazor_frontend.Services.ICategoryService categoryService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Quản lý Sản phẩm</PageTitle>

<div class="bg-white rounded-lg shadow-sm w-full h-full p-6">
    @if (!isAuthorized)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-red-700">Bạn không có quyền truy cập trang này.</div>
    }
    else
    {
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between mb-6">
            <div>
                <h2 class="text-2xl font-bold text-gray-800">Quản lý Sản phẩm</h2>
                <p class="text-sm text-gray-500 mt-1">Tạo, cập nhật và xóa sản phẩm trong Catalog Service.</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <input class="rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="Tìm theo tên sản phẩm" @bind="searchText" />
                <button class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors flex items-center gap-2 shadow-sm" @onclick="New">
                    <i class="ph ph-plus-circle text-xl"></i>
                    Thêm sản phẩm
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="mb-4 rounded-lg border @(isError ? "border-red-200 bg-red-50 text-red-700" : "border-green-200 bg-green-50 text-green-700") px-4 py-3 text-sm">
                @message
            </div>
        }

        <div class="overflow-x-auto border border-gray-200 rounded-lg">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-100 text-gray-600 text-sm uppercase tracking-wider">
                        <th class="p-4 font-semibold border-b border-gray-200">Tên sản phẩm</th>
                        <th class="p-4 font-semibold border-b border-gray-200">Danh mục</th>
                        <th class="p-4 font-semibold border-b border-gray-200">Mô tả</th>
                        <th class="p-4 font-semibold border-b border-gray-200 text-center">Biến thể</th>
                        <th class="p-4 font-semibold border-b border-gray-200 text-right">Thao tác</th>
                        <th class="p-4 font-semibold border-b border-gray-200 text-right">Ảnh</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700 text-sm">
                    @if (isLoading)
                    {
                        <tr><td colspan="6" class="p-4">Đang tải...</td></tr>
                    }
                    else if (!FilteredItems.Any())
                    {
                        <tr><td colspan="6" class="p-4">Chưa có sản phẩm nào</td></tr>
                    }
                    else
                    {
                        @foreach (var sp in FilteredItems)
                        {
                            var catName = categories.FirstOrDefault(c => c.MaDM == sp.MaDM)?.TenDM ?? sp.MaDM.ToString();
                            var previewImage = sp.ChiTietSanPhams?.FirstOrDefault()?.Anh ?? "product1.jpg";
                            <tr class="border-b border-gray-100 hover:bg-blue-50/50 transition-colors">
                                <td class="p-4 align-top">
                                    <p class="font-bold text-gray-800">@sp.TenSP</p>
                                </td>

                                <td class="p-4 align-top">
                                    <div class="flex flex-col gap-1">
                                        <span class="inline-flex items-center w-fit px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">@catName</span>
                                        <span class="text-xs text-gray-500">@categories.FirstOrDefault(c => c.MaDM == sp.MaDM)?.TenLDM</span>
                                    </div>
                                </td>

                                <td class="p-4 align-top">
                                    <div class="text-sm text-gray-600 line-clamp-2">@(!string.IsNullOrWhiteSpace(sp.MoTa) ? sp.MoTa : "-")</div>
                                </td>

                                <td class="p-4 text-center align-top">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">@((sp.ChiTietSanPhams?.Count ?? 0)) biến thể</span>
                                </td>

                                <td class="p-4 text-right space-x-2 align-top">
                                    <button class="p-1.5 text-blue-500 hover:bg-blue-100 rounded transition-colors" title="Chỉnh sửa" @onclick="() => Edit(sp)">
                                        <i class="ph ph-pencil-simple text-xl"></i>
                                    </button>
                                    <button class="p-1.5 text-red-500 hover:bg-red-100 rounded transition-colors" title="Xóa" @onclick="() => Delete(sp.MaSP)">
                                        <i class="ph ph-trash text-xl"></i>
                                    </button>
                                </td>

                                <td class="p-4 text-right align-top">
                                    <img src="@previewImage" alt="@sp.TenSP" class="inline-block h-12 w-12 rounded object-cover border border-gray-200" onerror="this.src='product1.jpg';" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showEditor)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4" @onclick="CloseEditor">
        <div class="w-full max-w-2xl rounded-2xl bg-white p-6 shadow-2xl" @onclick:stopPropagation="true">
            <div class="mb-6 flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-bold text-gray-900">@(editingId == Guid.Empty ? "Thêm sản phẩm" : "Chỉnh sửa sản phẩm")</h3>
                    <p class="text-sm text-gray-500">Nhập thông tin cơ bản cho sản phẩm.</p>
                </div>
                <button class="rounded-full p-2 text-gray-500 hover:bg-gray-100" @onclick="CloseEditor">✕</button>
            </div>

            <div class="grid grid-cols-1 gap-4">
                <div>
                    <label class="mb-1 block text-sm font-medium text-gray-700">Tên sản phẩm</label>
                    <input class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" @bind="editor.TenSP" />
                </div>

                <div>
                    <label class="mb-1 block text-sm font-medium text-gray-700">Danh mục</label>
                    <select class="w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" @bind="editor.MaDM">
                        <option value="@Guid.Empty">-- Chọn danh mục --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.MaDM">@cat.TenLDM - @cat.TenDM</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="mb-1 block text-sm font-medium text-gray-700">Mô tả</label>
                    <textarea class="min-h-28 w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" @bind="editor.MoTa"></textarea>
                </div>
            </div>

            <div class="mt-6 flex items-center justify-end gap-3">
                <button class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" @onclick="CloseEditor">Hủy</button>
                <button class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" @onclick="Save">Lưu</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private int CurrentPage { get; set; } = 1;
    private int TotalPages { get; set; } = 1;
    private List<SanPhamDto> items = new();
    private List<DanhMucDto> categories = new();
    private bool showEditor = false;
    private SanPhamCreateRequest editor = new();
    private Guid editingId = Guid.Empty;
    private bool isAuthorized;
    private string searchText = string.Empty;
    private string? message;
    private bool isError;

    private IEnumerable<SanPhamDto> FilteredItems
        => string.IsNullOrWhiteSpace(searchText)
            ? items
            : items.Where(x => x.TenSP.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var role = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "auth_role") ?? string.Empty;
        var isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
        var isStaff = string.Equals(role, "Staff", StringComparison.OrdinalIgnoreCase);
        isAuthorized = isAdmin || isStaff;

        if (!isAuthorized)
        {
            Navigation.NavigateTo("/account/signin?returnUrl=/admin/products");
            return;
        }

        await Load();
    }

    private async Task Load()
    {
        isLoading = true;
        try
        {
            categories = (await categoryService.GetAllAsync()).ToList();
            items = (await productService.GetAllAsync()).ToList();
            message = null;
        }
        catch (Exception ex)
        {
            message = $"Không tải được dữ liệu: {ex.Message}";
            isError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void New()
    {
        editingId = Guid.Empty;
        editor = new SanPhamCreateRequest { MaDM = categories.FirstOrDefault()?.MaDM ?? Guid.Empty };
        showEditor = true;
    }

    private void Edit(SanPhamDto it)
    {
        editingId = it.MaSP;
        editor = new SanPhamCreateRequest { MaDM = it.MaDM, TenSP = it.TenSP, MoTa = it.MoTa };
        showEditor = true;
    }

    private void CloseEditor()
    {
        showEditor = false;
    }

    private async Task Save()
    {
        if (editor.MaDM == Guid.Empty || string.IsNullOrWhiteSpace(editor.TenSP))
        {
            message = "Vui lòng nhập tên sản phẩm và chọn danh mục.";
            isError = true;
            return;
        }

        try
        {
            if (editingId == Guid.Empty)
            {
                var res = await productService.CreateAsync(editor);
                if (res != null)
                {
                    message = "Đã tạo sản phẩm.";
                    isError = false;
                }
                else
                {
                    message = "Tạo sản phẩm thất bại.";
                    isError = true;
                }
            }
            else
            {
                var ok = await productService.UpdateAsync(editingId, editor);
                if (ok)
                {
                    message = "Đã cập nhật sản phẩm.";
                    isError = false;
                }
                else
                {
                    message = "Cập nhật sản phẩm thất bại.";
                    isError = true;
                }
            }

            if (!isError)
            {
                await Load();
                showEditor = false;
            }
        }
        catch (Exception ex)
        {
            message = $"Lưu sản phẩm thất bại: {ex.Message}";
            isError = true;
        }
    }

    private async Task Delete(Guid id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Bạn chắc chắn muốn xóa sản phẩm này?");
        if (!confirmed)
        {
            return;
        }

        var ok = await productService.DeleteAsync(id);
        if (ok)
        {
            message = "Đã xóa sản phẩm.";
            isError = false;
            await Load();
        }
        else
        {
            message = "Xóa sản phẩm thất bại.";
            isError = true;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            CurrentPage = page;
        }
    }

    private string GetColorClass(string mau)
    {
        return mau.ToLower() switch
        {
            "đỏ" => "bg-red-500 text-white",
            "xanh" => "bg-blue-500 text-white",
            "xanh dương" => "bg-blue-600 text-white",
            "xanh lá" => "bg-green-500 text-white",
            "đen" => "bg-gray-800 text-white",
            "trắng" => "bg-white text-gray-800 border border-gray-300",
            "xám" => "bg-gray-500 text-white",
            "vàng" => "bg-yellow-400 text-gray-800",
            "hồng" => "bg-pink-400 text-white",
            "tím" => "bg-purple-500 text-white",
            "cam" => "bg-orange-500 text-white",
            _ => "bg-gray-300 text-gray-800"
        };
    }
}
