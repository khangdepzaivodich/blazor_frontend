@page "/account/signin"
@layout blazor_frontend.Layout.AccountLayout
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IAuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject blazor_frontend.Services.AuthState AuthState

<div class="space-y-4">
    <div class="text-center">
        <h1 class="text-2xl font-bold">Welcome back</h1>
        <p class="text-sm text-gray-600">Sign in to access your orders, wishlist and faster checkout.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-3 rounded bg-red-50 text-red-700 border border-red-100">
            @errorMessage
        </div>
    }

    <EditForm Model="model" OnValidSubmit="HandleValidSubmit" class="space-y-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label class="block text-sm text-gray-600 mb-1">Email</label>
            <InputText class="w-full border px-3 py-2 rounded-lg" @bind-Value="model.Email" />
            <ValidationMessage For="@(() => model.Email)" />
        </div>

        <div>
            <label class="block text-sm text-gray-600 mb-1">Password</label>
            <InputText class="w-full border px-3 py-2 rounded-lg" type="password" @bind-Value="model.MatKhau" />
            <ValidationMessage For="@(() => model.MatKhau)" />
        </div>

        <button class="w-full flex items-center justify-center gap-2 bg-blue-700 text-white py-2 rounded-lg" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <svg class="animate-spin h-4 w-4 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign in</span>
            }
        </button>

        <div class="flex items-center justify-between text-sm text-gray-500">
            <a href="/account/signup" class="text-blue-700 hover:underline">Create account</a>
            <a href="#" class="hover:underline">Forgot password?</a>
        </div>
    </EditForm>
</div>

@code {
    private LoginRequest model = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var res = await AuthService.LoginAsync(model);

            if (res == null || string.IsNullOrEmpty(res.Token))
            {
                errorMessage = "Invalid email or password.";
                return;
            }

            // persist and update UI state
            await JS.InvokeVoidAsync("localStorage.setItem", "auth_token", res.Token);
            await JS.InvokeVoidAsync("localStorage.setItem", "auth_user_id", res.UserId.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", "auth_ho_ten", res.HoTen ?? "");

            AuthState.SetUser(res.Token, res.UserId, res.Email ?? "", res.Role ?? "User", res.HoTen ?? "");

            Nav.NavigateTo("/", true);
        }
        catch (Exception ex)
        {
            errorMessage = "Sign in failed: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}