@page "/account/signin"
@using System.Text.Json
@using System.ComponentModel.DataAnnotations
@using System.Linq
@using blazor_frontend.Models
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="space-y-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Sign in</h1>
        <p class="text-sm text-gray-600">Use your phone number to sign in to your account.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="mb-2 p-3 rounded bg-red-50 text-red-700 border border-red-100">@errorMessage</div>
    }

    <EditForm Model="model" OnValidSubmit="HandleValidSubmit" class="space-y-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
            <InputText class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-[#cfe2ff]" @bind-Value="model.SoDienThoai" />
            <ValidationMessage For="@(() => model.SoDienThoai)" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <InputText class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-[#cfe2ff]" @bind-Value="model.Password" type="password" />
            <ValidationMessage For="@(() => model.Password)" />
        </div>

        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <input id="remember" type="checkbox" class="h-4 w-4 text-[#0b3b72] rounded" />
                <label for="remember" class="text-sm text-gray-600">Remember me</label>
            </div>
            <a class="text-sm text-[#0b3b72] hover:underline" href="#">Forgot password?</a>
        </div>

        <div class="flex flex-col gap-3">
            <button class="w-full bg-[#0b3b72] text-white px-4 py-2 rounded font-semibold" type="submit" disabled="@isSubmitting">
                @if (isSubmitting) { <span>Signing in...</span> } else { <span>Sign in</span> }
            </button>

            <div class="text-center text-sm text-gray-600">
                Or sign in with
            </div>

            <div class="flex gap-3">
                <button class="flex-1 border border-gray-200 rounded py-2 flex items-center justify-center gap-2 hover:bg-gray-50">
                    <img src="/static/facebook.png" alt="fb" class="w-5 h-5" onerror="this.style.display='none'" /> Facebook
                </button>
                <button class="flex-1 border border-gray-200 rounded py-2 flex items-center justify-center gap-2 hover:bg-gray-50">
                    <img src="/static/google.png" alt="g" class="w-5 h-5" onerror="this.style.display='none'" /> Google
                </button>
            </div>

            <div class="text-sm text-gray-600 text-center">
                Don't have an account? <a class="text-[#0b3b72] hover:underline" href="/account/signup">Create one</a>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private SignInModel model = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            var existing = MockStoreData.GetMockTaiKhoans()
                                       .FirstOrDefault(t => t.SoDienThoai == model.SoDienThoai);

            TaiKhoan account;
            if (existing != null)
            {
                account = existing;
            }
            else
            {
                var suffix = model.SoDienThoai != null && model.SoDienThoai.Length >= 4
                    ? model.SoDienThoai[^4..]
                    : model.SoDienThoai ?? "user";

                account = new TaiKhoan
                {
                    MaTK = Guid.NewGuid(),
                    SoDienThoai = model.SoDienThoai ?? string.Empty,
                    HoTen = string.IsNullOrWhiteSpace(model.DisplayName) ? ("user" + suffix) : model.DisplayName,
                    DiaChi = string.Empty,
                    TrangThai = true,
                    NgayTao = DateTime.Now
                };
            }

            var json = JsonSerializer.Serialize(account);
            await JS.InvokeVoidAsync("localStorage.setItem", "user_account", json);

            Nav.NavigateTo("/account/profile");
        }
        catch (Exception ex)
        {
            errorMessage = "Sign in failed. Open browser console for details.";
            await JS.InvokeVoidAsync("console.error", ex.ToString());
        }
        finally
        {
            isSubmitting = false;
        }
    }

    class SignInModel
    {
        [Required]
        public string SoDienThoai { get; set; } = string.Empty;

        [Required, MinLength(3)]
        public string Password { get; set; } = string.Empty;

        public string? DisplayName { get; set; }
    }
}