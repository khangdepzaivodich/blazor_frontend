@page "/account/signin"
@using Microsoft.AspNetCore.Components
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IAuthService AuthService
@inject blazor_frontend.Services.IBasketService BasketService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="space-y-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Sign in</h1>
        <p class="text-sm text-gray-600">Use your email to sign in to your account.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-3 rounded bg-red-50 text-red-700 border border-red-100">
            @errorMessage
        </div>
    }

    <EditForm Model="model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label>Email</label>
            <InputText class="w-full border px-3 py-2 rounded" @bind-Value="model.Email" />
        </div>

        <div>
            <label>Password</label>
            <InputText class="w-full border px-3 py-2 rounded" type="password" @bind-Value="model.MatKhau" />
        </div>

        <button class="w-full bg-blue-800 text-white py-2 rounded" disabled="@isSubmitting">
            @(isSubmitting ? "Signing in..." : "Sign in")
        </button>
    </EditForm>
</div>

@code {
    private LoginRequest model = new();
    private string? errorMessage;
    private bool isSubmitting;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var res = await AuthService.LoginAsync(model);

            if (res == null || string.IsNullOrEmpty(res.Token))
            {
                errorMessage = "Invalid email or password";
                return;
            }

            await JS.InvokeVoidAsync("localStorage.setItem", "auth_token", res.Token);
            await JS.InvokeVoidAsync("localStorage.setItem", "auth_user_id", res.UserId.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", "auth_ho_ten", res.HoTen ?? "");

            await MergeGuestCartAsync(res.UserId.ToString());

            Nav.NavigateTo(string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task MergeGuestCartAsync(string userId)
    {
        var guestBasket = await BasketService.GetBasketAsync("guest");
        if (guestBasket?.Items?.Any() != true)
        {
            return;
        }

        BasketDto? authBasket = null;
        try
        {
            authBasket = await BasketService.GetBasketAsync(userId);
        }
        catch
        {
            authBasket = null;
        }

        authBasket ??= new BasketDto { UserName = userId };

        foreach (var guestItem in guestBasket.Items)
        {
            var existing = authBasket.Items.FirstOrDefault(x => x.ProductId == guestItem.ProductId);
            if (existing != null)
            {
                existing.Quantity += guestItem.Quantity;
                continue;
            }

            authBasket.Items.Add(new BasketItemDto
            {
                ProductId = guestItem.ProductId,
                ProductName = guestItem.ProductName,
                Price = guestItem.Price,
                Quantity = guestItem.Quantity,
                ImageUrl = guestItem.ImageUrl
            });
        }

        await BasketService.UpdateBasketAsync(authBasket);
        await BasketService.DeleteBasketAsync("guest");
    }
}