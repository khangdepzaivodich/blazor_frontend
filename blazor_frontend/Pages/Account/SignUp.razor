@page "/account/signup"
@using System.Text.Json
@using System.ComponentModel.DataAnnotations
@using blazor_frontend.Models
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="space-y-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Create account</h1>
        <p class="text-sm text-gray-600">Join Serious — manage orders, save favorites, and checkout faster.</p>
    </div>

    <EditForm Model="model" OnValidSubmit="HandleValidSubmit" class="space-y-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full name</label>
            <InputText class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-[#cfe2ff]" @bind-Value="model.HoTen" />
            <ValidationMessage For="@(() => model.HoTen)" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
            <InputText class="w-full border rounded px-3 py-2" @bind-Value="model.SoDienThoai" />
            <ValidationMessage For="@(() => model.SoDienThoai)" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
            <InputText class="w-full border rounded px-3 py-2" @bind-Value="model.DiaChi" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <InputText class="w-full border rounded px-3 py-2" @bind-Value="model.Password" type="password" />
            <ValidationMessage For="@(() => model.Password)" />
        </div>

        <div class="flex flex-col gap-3">
            <button class="w-full bg-[#0b3b72] text-white px-4 py-2 rounded font-semibold" type="submit">Create account</button>

            <div class="text-sm text-gray-600 text-center">
                Already have an account? <a class="text-[#0b3b72] hover:underline" href="/account/signin">Sign in</a>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private SignUpModel model = new();

    private async Task HandleValidSubmit()
    {
        var account = new TaiKhoan
        {
            MaTK = Guid.NewGuid(),
            HoTen = model.HoTen,
            SoDienThoai = model.SoDienThoai,
            DiaChi = model.DiaChi,
            TrangThai = true,
            NgayTao = DateTime.Now
        };

        var json = JsonSerializer.Serialize(account);
        await JS.InvokeVoidAsync("localStorage.setItem", "user_account", json);

        Nav.NavigateTo("/account/profile");
    }

    class SignUpModel
    {
        [Required] public string HoTen { get; set; } = string.Empty;
        [Required] public string SoDienThoai { get; set; } = string.Empty;
        public string DiaChi { get; set; } = string.Empty;
        [Required, MinLength(6)] public string Password { get; set; } = string.Empty;
    }
}