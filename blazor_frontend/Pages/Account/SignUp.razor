@page "/account/signup"
@layout blazor_frontend.Layout.AccountLayout
@using blazor_frontend.Models.BackendDTOs
@inject blazor_frontend.Services.IAuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject blazor_frontend.Services.AuthState AuthState

<div class="space-y-4">

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded">@errorMessage</div>
    }

    <EditForm Model="model" OnValidSubmit="HandleValidSubmit" class="max-w-md mx-auto bg-white rounded-xl shadow-md p-6 space-y-3">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div>
            <label class="block text-sm text-gray-600">Full name</label>
            <InputText class="w-full border px-3 py-2 rounded" @bind-Value="model.HoTen" />
        </div>

        <div>
            <label class="block text-sm text-gray-600">Email</label>
            <InputText class="w-full border px-3 py-2 rounded" @bind-Value="model.Email" />
        </div>

        <div>
            <label class="block text-sm text-gray-600">Phone</label>
            <InputText class="w-full border px-3 py-2 rounded" @bind-Value="model.SoDienThoai" />
        </div>

        <div>
            <label class="block text-sm text-gray-600">Password</label>
            <InputText class="w-full border px-3 py-2 rounded" type="password" @bind-Value="model.MatKhau" />
        </div>

        <button class="w-full bg-blue-800 text-white py-2 rounded" disabled="@isLoading">
            @(isLoading ? "Creating..." : "Create account")
        </button>

        <div class="text-center text-sm text-gray-600">
            <a href="/account/signin" class="text-blue-700 hover:underline">Already have an account? Sign in</a>
        </div>
    </EditForm>
</div>

@code {
    private RegisterRequest model = new();
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            var result = await AuthService.RegisterAsync(model);

            if (result == null)
            {
                errorMessage = "Unable to contact server. Please try again.";
                return;
            }

            if (!result.Success)
            {
                errorMessage = result.Message ?? "Registration failed.";
                return;
            }

            // Registration succeeded. Attempt explicit login with the same credentials.
            var loginReq = new LoginRequest
            {
                Email = model.Email,
                MatKhau = model.MatKhau
            };  

            var loginRes = await AuthService.LoginAsync(loginReq);

            if (loginRes != null && !string.IsNullOrEmpty(loginRes.Token))
            {
                Nav.NavigateTo("/", true);
                return;
            }

            // If login didn't succeed, send user to sign-in page
            Nav.NavigateTo("/account/signin");
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}