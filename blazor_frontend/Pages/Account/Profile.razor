@page "/account/profile"
@layout blazor_frontend.Layout.AccountProfileLayout
@using System.Text.Json
@using System.IO
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using blazor_frontend.Models
@inject IJSRuntime JS
@inject NavigationManager Nav

<!-- Use a centered container so profile UI does not overlap the site's hero -->
<div class="min-h-[calc(100vh-4rem)] flex items-start justify-center py-10">
    <div class="w-full max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-8">

        <!-- Sidebar -->
        <aside class="lg:col-span-1 bg-white rounded-2xl shadow p-5">
            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Account settings</h3>

            <nav class="flex flex-col gap-2 text-sm">
                <a href="/account/profile" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-blue-50 text-blue-700 font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4a2 2 0 002 2h10a2 2 0 002-2V3"/></svg>
                    Profile Settings
                </a>

                <a href="/account/messages" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50 text-gray-600 transition">
                     <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Tin nhắn
                </a>

                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50" href="#">Password</a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50" href="#">Notifications</a>
                <a class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-50" href="#">Verification</a>
            </nav>
        </aside>

        <!-- Main -->
        <main class="lg:col-span-4 space-y-6">
            <!-- Header -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-2xl p-6 shadow">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-full bg-white/20 flex items-center justify-center text-xl font-bold">
                        @GetInitials(profile.FullName)
                    </div>
                    <div>
                        <h2 class="text-xl font-semibold">@profile.FullName</h2>
                        <p class="text-sm opacity-80">Manage your personal information</p>
                    </div>
                </div>
            </div>

            <!-- Profile Card -->
            <div class="bg-white rounded-2xl shadow p-6">
                <div class="flex items-start gap-6 mb-6">
                    <!-- Avatar -->
                    <div class="flex flex-col items-center w-48">
                        <div class="relative">
                            @if (!string.IsNullOrEmpty(avatarDataUrl))
                            {
                                <img src="@avatarDataUrl" alt="Avatar" class="w-28 h-28 rounded-full object-cover border" />
                            }
                            else
                            {
                                <div class="w-28 h-28 rounded-full bg-gray-100 flex items-center justify-center text-2xl font-semibold text-gray-700 border">
                                    @GetInitials(account?.HoTen ?? profile.FullName)
                                </div>
                            }

                            <button class="absolute -bottom-1 -right-1 bg-white border rounded-full p-1 shadow" title="Change avatar" @onclick="TriggerFileInput">
                                <svg class="w-4 h-4 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V7M16 3h-4l-2 4h8l-2-4z"/></svg>
                            </button>

                            <InputFile id="avatarInput" class="hidden" OnChange="OnInputFileChange" accept="image/*" />
                        </div>

                        <div class="mt-3 flex gap-2">
                            <button class="px-4 py-2 bg-[#0b3b72] text-white rounded text-sm" @onclick="TriggerFileInput">Upload New</button>
                            <button class="px-3 py-2 border rounded text-sm" @onclick="DeleteAvatar">Delete avatar</button>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="mt-3 text-sm text-green-700 text-center">@message</div>
                        }
                    </div>

                    <!-- Form -->
                    <div class="flex-1">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-semibold">Personal Info</h3>
                            @if (!isEditing)
                            {
                                <button class="px-4 py-2 text-sm bg-gray-100 hover:bg-gray-200 rounded-lg" @onclick="StartEdit">Edit</button>
                            }
                        </div>

                        <EditForm Model="profile" OnValidSubmit="SaveChanges">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-sm text-red-600 mb-2" />

                            <div class="grid md:grid-cols-2 gap-5">
                                <div>
                                    <label class="text-xs text-gray-500">First Name</label>
                                    <InputText class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" @bind-Value="profile.FirstName" disabled="@(!isEditing)" />
                                    <ValidationMessage For="@(() => profile.FirstName)" />
                                </div>

                                <div>
                                    <label class="text-xs text-gray-500">Last Name</label>
                                    <InputText class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" @bind-Value="profile.LastName" disabled="@(!isEditing)" />
                                    <ValidationMessage For="@(() => profile.LastName)" />
                                </div>

                                <div>
                                    <label class="text-xs text-gray-500">Email</label>
                                    <InputText class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" @bind-Value="profile.Email" disabled="@(!isEditing)" />
                                </div>

                                <div>
                                    <label class="text-xs text-gray-500">Phone</label>
                                    <InputText class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" @bind-Value="profile.Mobile" disabled="@(!isEditing)" />
                                    <ValidationMessage For="@(() => profile.Mobile)" />
                                </div>

                                <div class="md:col-span-2">
                                    <label class="text-xs text-gray-500">Address</label>
                                    <InputTextArea class="w-full mt-1 px-3 py-2 border rounded-lg h-24 focus:ring-2 focus:ring-blue-500" @bind-Value="profile.ResidentialAddress" disabled="@(!isEditing)" />
                                </div>
                            </div>

                            @if (isEditing)
                            {
                                <div class="flex gap-3 pt-4">
                                    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700">Save</button>
                                    <button type="button" class="px-4 py-2 bg-gray-100 rounded-lg" @onclick="CancelEdit">Cancel</button>
                                </div>
                            }
                        </EditForm>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@code {
    private TaiKhoan? account;
    private ProfileModel profile = new();
    private bool isEditing;
    private string? avatarDataUrl;
    private string? message;

    // backups for cancel
    private ProfileModel? backupProfile;
    private TaiKhoan? backupAccount;
    private string? backupAvatar;
    private bool avatarChanged;

    protected override async Task OnInitializedAsync()
    {
        // load account (TaiKhoan) if available
        var accJson = await JS.InvokeAsync<string>("localStorage.getItem", "user_account");
        if (!string.IsNullOrEmpty(accJson))
        {
            try { account = JsonSerializer.Deserialize<TaiKhoan>(accJson); }
            catch { account = null; }
        }

        // load profile extras (if any)
        var profJson = await JS.InvokeAsync<string>("localStorage.getItem", "user_profile");
        if (!string.IsNullOrEmpty(profJson))
        {
            try { profile = JsonSerializer.Deserialize<ProfileModel>(profJson) ?? new ProfileModel(); }
            catch { profile = new ProfileModel(); }
        }
        else if (account != null)
        {
            var names = (account.HoTen ?? string.Empty).Split(' ', StringSplitOptions.RemoveEmptyEntries);
            profile.FirstName = names.FirstOrDefault() ?? string.Empty;
            profile.LastName = names.Length > 1 ? names[^1] : string.Empty;
            profile.Mobile = account.SoDienThoai ?? string.Empty;
            profile.ResidentialAddress = account.DiaChi ?? string.Empty;
            profile.Email = string.Empty;
        }

        avatarDataUrl = await JS.InvokeAsync<string>("localStorage.getItem", "user_avatar");
    }

    private void StartEdit()
    {
        // create deep copies for cancel
        backupProfile = new ProfileModel
        {
            FirstName = profile.FirstName,
            LastName = profile.LastName,
            Email = profile.Email,
            Mobile = profile.Mobile,
            Gender = profile.Gender,
            IdNumber = profile.IdNumber,
            TaxNumber = profile.TaxNumber,
            TaxCountry = profile.TaxCountry,
            ResidentialAddress = profile.ResidentialAddress
        };

        if (account != null)
        {
            backupAccount = new TaiKhoan
            {
                MaTK = account.MaTK,
                HoTen = account.HoTen,
                SoDienThoai = account.SoDienThoai,
                DiaChi = account.DiaChi,
                VaiTro = account.VaiTro,
                TrangThai = account.TrangThai,
                NgayTao = account.NgayTao,
                LastActiveAt = account.LastActiveAt
            };
        }

        backupAvatar = avatarDataUrl;
        avatarChanged = false;

        isEditing = true;
        message = null;
    }

    private void CancelEdit()
    {
        if (backupProfile != null)
        {
            profile = backupProfile;
            backupProfile = null;
        }

        if (backupAccount != null)
        {
            account = backupAccount;
            backupAccount = null;
        }

        avatarDataUrl = backupAvatar;
        avatarChanged = false;
        isEditing = false;
        message = "Edit canceled.";
    }

    private async Task SaveChanges()
    {
        // basic validation: ensure first/last/mobile present
        if (string.IsNullOrWhiteSpace(profile.FirstName) || string.IsNullOrWhiteSpace(profile.LastName) || string.IsNullOrWhiteSpace(profile.Mobile))
        {
            message = "Please fill required fields (first name, last name, mobile).";
            return;
        }

        // persist profile extras
        var profJson = JsonSerializer.Serialize(profile);
        await JS.InvokeVoidAsync("localStorage.setItem", "user_profile", profJson);

        // update TaiKhoan (keep using existing model)
        if (account != null)
        {
            account.HoTen = $"{profile.FirstName} {profile.LastName}".Trim();
            account.SoDienThoai = profile.Mobile;
            account.DiaChi = profile.ResidentialAddress;
            account.LastActiveAt = DateTime.Now;
            var accJson = JsonSerializer.Serialize(account);
            await JS.InvokeVoidAsync("localStorage.setItem", "user_account", accJson);
        }

        // persist avatar only when changed during edit
        if (avatarChanged)
        {
            if (!string.IsNullOrEmpty(avatarDataUrl))
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "user_avatar", avatarDataUrl);
            }
            else
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "user_avatar");
            }
            avatarChanged = false;
        }

        // clear backups
        backupProfile = null;
        backupAccount = null;
        backupAvatar = null;

        isEditing = false;
        message = "Profile saved successfully.";
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(5_000_000).CopyToAsync(ms);
            var bytes = ms.ToArray();
            avatarDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            avatarChanged = true;
            message = "Avatar updated (preview). Remember to Save Changes.";
        }
        catch
        {
            message = "Failed to load image. Use a smaller image (max 5 MB).";
        }
    }

    private async Task DeleteAvatar()
    {
        if (isEditing)
        {
            avatarDataUrl = null;
            avatarChanged = true;
            message = "Avatar removed (will be deleted after Save).";
        }
        else
        {
            avatarDataUrl = null;
            await JS.InvokeVoidAsync("localStorage.removeItem", "user_avatar");
            message = "Avatar deleted.";
        }
    }

    private async Task TriggerFileInput()
    {
        // programmatically open the hidden file input
        await JS.InvokeVoidAsync("eval", "document.getElementById('avatarInput')?.click();");
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper();
    }

    public class ProfileModel
    {
        [Required] public string FirstName { get; set; } = string.Empty;
        [Required] public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        [Required] public string Mobile { get; set; } = string.Empty;
        public string Gender { get; set; } = string.Empty;
        public string IdNumber { get; set; } = string.Empty;
        public string TaxNumber { get; set; } = string.Empty;
        public string TaxCountry { get; set; } = string.Empty;
        public string ResidentialAddress { get; set; } = string.Empty;
        public string FullName => $"{FirstName} {LastName}".Trim();
    }
}