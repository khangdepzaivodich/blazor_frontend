@page "/account/profile"
@layout blazor_frontend.Layout.AccountProfileLayout

@using System.Text.Json
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@using blazor_frontend.Models
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject blazor_frontend.Services.IAuthService AuthService
@inject blazor_frontend.Services.AuthState AuthState

<div class="min-h-[80vh] flex items-center justify-center">

    <div class="w-full max-w-5xl">

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

            <!-- SIDEBAR -->
            <aside class="bg-white border border-gray-200 rounded-2xl p-4 h-fit">
                <h3 class="text-xs font-semibold text-gray-400 uppercase mb-4">Account</h3>

                <nav class="flex flex-col gap-1 text-sm">
                    <a href="/account/profile"
                       class="px-4 py-3 rounded-xl bg-blue-600 text-white font-medium">
                        Profile
                    </a>

                    <a href="/account/orders"
                       class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                        Đơn hàng của tôi
                    </a>

                    <a href="/account/messages"
                       class="px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-100">
                        Messages
                    </a>
                </nav>
            </aside>

            <!-- MAIN -->
            <main class="lg:col-span-3 space-y-4">

                <!-- HEADER -->
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-xl font-semibold text-gray-900">Profile</h1>
                        <p class="text-sm text-gray-500">Manage your account info</p>
                    </div>

                    @if (!isEditing)
                    {
                        <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
                                @onclick="StartEdit">
                            Edit
                        </button>
                    }
                    else
                    {
                        <span class="text-xs px-3 py-1 bg-blue-100 text-blue-700 rounded-full">
                            Editing
                        </span>
                    }
                </div>

                <!-- CARD -->
                <div class="bg-white border rounded-2xl p-6
                            @(isEditing ? "border-blue-400 ring-1 ring-blue-200" : "border-gray-200")">

                    <div class="flex flex-col md:flex-row gap-8">

                        <!-- AVATAR -->
                        <div class="flex flex-col items-center gap-3 w-full md:w-48">
                            @if (!string.IsNullOrEmpty(avatarDataUrl))
                            {
                                <img src="@avatarDataUrl"
                                     class="w-24 h-24 rounded-full object-cover border ring-2 ring-gray-100 shadow-sm" />
                            }
                            else
                            {
                                <div class="w-24 h-24 rounded-full bg-gray-100 flex items-center justify-center text-lg font-semibold ring-2 ring-gray-100 shadow-sm">
                                    @GetInitials(account.HoTen)
                                </div>
                            }

                            <div class="flex gap-2">
                                <button class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-lg hover:bg-blue-700"
                                        @onclick="TriggerFileInput">
                                    Upload
                                </button>

                                <button class="px-3 py-1.5 text-xs text-red-500 border border-gray-200 rounded-lg hover:bg-red-50"
                                        @onclick="DeleteAvatar">
                                    Delete
                                </button>
                            </div>

                            <InputFile id="avatarInput" class="hidden" OnChange="OnInputFileChange" accept="image/*" />
                        </div>

                        <!-- FORM -->
                        <div class="flex-1">
                            <EditForm Model="account" OnValidSubmit="SaveChanges">

                                <div class="grid md:grid-cols-2 gap-5">

                                    <div>
                                        <label class="text-xs text-gray-500">Full Name</label>
                                        <InputText class="w-full mt-1 px-3 py-2 border rounded-xl bg-white
                                                         focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500
                                                         disabled:bg-gray-100 disabled:text-gray-400"
                                                   @bind-Value="account.HoTen"
                                                   disabled="@(!isEditing)" />
                                    </div>

                                    <div>
                                        <label class="text-xs text-gray-500">Phone</label>
                                        <InputText class="w-full mt-1 px-3 py-2 border rounded-xl bg-white
                                                         focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500
                                                         disabled:bg-gray-100 disabled:text-gray-400"
                                                   @bind-Value="account.SoDienThoai"
                                                   disabled="@(!isEditing)" />
                                    </div>

                                    <div>
                                        <label class="text-xs text-gray-500">Role</label>
                                        <InputText class="w-full mt-1 px-3 py-2 border rounded-xl bg-gray-100 text-gray-500"
                                                   @bind-Value="account.VaiTro"
                                                   disabled />
                                    </div>

                                    <div class="md:col-span-2">
                                        <label class="text-xs text-gray-500">Address</label>
                                        <InputTextArea class="w-full mt-1 px-3 py-2 border rounded-xl h-24 bg-white
                                                              focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500
                                                              disabled:bg-gray-100 disabled:text-gray-400"
                                                       @bind-Value="account.DiaChi"
                                                       disabled="@(!isEditing)" />
                                    </div>
                                </div>

                                @if (isEditing)
                                {
                                    <div class="flex gap-3 mt-6">
                                        <button type="submit"
                                                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
                                            Save
                                        </button>

                                        <button type="button"
                                                class="px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200"
                                                @onclick="CancelEdit">
                                            Cancel
                                        </button>
                                    </div>
                                }

                                <div class="mt-6">
                                    <button type="button"
                                            class="px-4 py-2 rounded-lg border border-red-200 text-red-600 hover:bg-red-50"
                                            @onclick="LogoutAsync">
                                        Đăng xuất
                                    </button>
                                </div>
                            </EditForm>

                            @if (!string.IsNullOrEmpty(message))
                            {
                                <div class="mt-4 text-sm text-green-600">@message</div>
                            }
                        </div>

                    </div>
                </div>
            </main>
        </div>
    </div>
</div>

@code {
    private TaiKhoan account = new();
    private TaiKhoan backup = new();

    private bool isEditing;
    private string? avatarDataUrl;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "auth_token");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/account/signin?returnUrl=/account/profile");
            return;
        }

        var json = await JS.InvokeAsync<string>("localStorage.getItem", "user_account");
        if (!string.IsNullOrEmpty(json))
        {
            account = JsonSerializer.Deserialize<TaiKhoan>(json) ?? new();
        }

        avatarDataUrl = await JS.InvokeAsync<string>("localStorage.getItem", "user_avatar");
    }

    private void StartEdit()
    {
        backup = new TaiKhoan
        {
            MaTK = account.MaTK,
            HoTen = account.HoTen,
            SoDienThoai = account.SoDienThoai,
            DiaChi = account.DiaChi,
            VaiTro = account.VaiTro,
            TrangThai = account.TrangThai,
            NgayTao = account.NgayTao,
            LastActiveAt = account.LastActiveAt
        };

        isEditing = true;
        message = null;
    }

    private void CancelEdit()
    {
        account = backup;
        isEditing = false;
        message = "Canceled";
    }

    private async Task SaveChanges()
    {
        account.LastActiveAt = DateTime.Now;

        var json = JsonSerializer.Serialize(account);
        await JS.InvokeVoidAsync("localStorage.setItem", "user_account", json);

        if (!string.IsNullOrEmpty(avatarDataUrl))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "user_avatar", avatarDataUrl);
        }

        isEditing = false;
        message = "Saved";
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        AuthState.Clear();
        Nav.NavigateTo("/account/signin", true);
    }

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var ms = new MemoryStream();
        await file.OpenReadStream(5_000_000).CopyToAsync(ms);
        avatarDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task DeleteAvatar()
    {
        avatarDataUrl = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", "user_avatar");
    }

    private async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('avatarInput').click()");
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][0].ToString().ToUpper()
            : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}