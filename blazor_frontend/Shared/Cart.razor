@page "/cart"
@using Microsoft.AspNetCore.Components
@using blazor_frontend.Models
@inject IBasketService BasketService
@inject IDiscountService DiscountService
@inject blazor_frontend.Services.IProductService ProductService
@inject blazor_frontend.Services.ICategoryService CategoryService
@inject IOrderService OrderService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="max-w-[1200px] mx-auto px-4 md:px-6 py-6 pb-32">
    <div class="text-sm text-gray-500 mb-6 flex items-center gap-2">
        <a href="/" class="text-blue-500 hover:underline">Trang chủ</a>
        <span>/</span>
        <a href="/products" class="text-blue-500 hover:underline">Danh mục</a>
        <span>/</span>
        <span class="text-gray-700">Giỏ hàng</span>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        <div class="w-full lg:w-3/5 space-y-8">
            <section>
                <h2 class="text-xl font-bold text-gray-900 mb-4">Thông tin đơn hàng</h2>
                <div class="space-y-4">
                    <div>
                        <input type="text" placeholder="Họ và tên" @bind="HoTen" class="@GetFieldClass(HoTen)" />
                        @if (ShowFieldError(HoTen))
                        {
                            <div class="mt-1 text-xs text-red-600">Họ và tên là bắt buộc.</div>
                        }
                    </div>

                    <div>
                        <input type="tel" placeholder="Số điện thoại" @bind="SoDienThoai" class="@GetFieldClass(SoDienThoai)" />
                        @if (ShowFieldError(SoDienThoai))
                        {
                            <div class="mt-1 text-xs text-red-600">Số điện thoại là bắt buộc.</div>
                        }
                    </div>

                    <div>
                        <input type="text" placeholder="Địa chỉ" @bind="DiaChi" class="@GetFieldClass(DiaChi)" />
                        @if (ShowFieldError(DiaChi))
                        {
                            <div class="mt-1 text-xs text-red-600">Địa chỉ là bắt buộc.</div>
                        }
                    </div>

                    <div>
                        <textarea placeholder="Ghi chú (không bắt buộc)" @bind="GhiChu" class="w-full border border-gray-300 rounded-md px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 min-h-24"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <select class="w-full border border-gray-300 rounded-md px-4 py-2.5 bg-white focus:outline-none focus:border-blue-500 text-gray-600" value="@SelectedProvinceCode" @onchange="OnProvinceChangedAsync">
                            <option value="">Chọn tỉnh/thành phố</option>
                            @foreach (var province in Provinces)
                            {
                                <option value="@province.Code">@province.Name</option>
                            }
                        </select>
                        <select class="w-full border border-gray-300 rounded-md px-4 py-2.5 bg-white focus:outline-none focus:border-blue-500 text-gray-600" value="@SelectedDistrictCode" @onchange="OnDistrictChangedAsync" disabled="@(!Districts.Any())">
                            <option value="">Chọn Quận/huyện</option>
                            @foreach (var district in Districts)
                            {
                                <option value="@district.Code">@district.Name</option>
                            }
                        </select>
                        <select class="w-full border border-gray-300 rounded-md px-4 py-2.5 bg-white focus:outline-none focus:border-blue-500 text-gray-600" value="@SelectedWardCode" @onchange="OnWardChanged" disabled="@(!Wards.Any())">
                            <option value="">Chọn Phường/xã</option>
                            @foreach (var ward in Wards)
                            {
                                <option value="@ward.Code">@ward.Name</option>
                            }
                        </select>
                    </div>

                    <input type="text" placeholder="Ví dụ: số nhà, tên đường" class="w-full border border-gray-300 rounded-md px-4 py-2.5 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" @bind="StreetAddress" />
                </div>
            </section>

            <section>
                <h2 class="text-xl font-bold text-gray-900 mb-4">Hình thức thanh toán</h2>
                <div class="space-y-3">
                    <div class="border @(PaymentMethod == 1 ? "border-[#0b3b72]" : "border-gray-200") rounded-md overflow-hidden cursor-pointer" @onclick="() => PaymentMethod = 1">
                        <div class="flex items-center gap-3 p-4">
                            <input type="radio" name="payment" checked="@(PaymentMethod == 1)" class="w-4 h-4 text-[#0b3b72] focus:ring-[#0b3b72]" />
                            <div class="bg-[#0b3b72] text-white text-xs font-bold px-2 py-1 rounded">COD</div>
                            <span class="text-gray-800">Thanh toán khi giao hàng (COD)</span>
                        </div>
                        @if (PaymentMethod == 1)
                        {
                            <div class="border-t border-gray-200 p-4 bg-gray-50 text-sm text-gray-600 space-y-1">
                                <p>- Khách hàng được kiểm tra hàng trước khi nhận hàng.</p>
                                <p>- Freeship đơn từ 399K</p>
                            </div>
                        }
                    </div>

                    <div class="border @(PaymentMethod == 2 ? "border-[#0b3b72]" : "border-gray-200") rounded-md flex items-center gap-3 p-4 cursor-pointer" @onclick="() => PaymentMethod = 2">
                        <input type="radio" name="payment" checked="@(PaymentMethod == 2)" class="w-4 h-4 text-[#0b3b72] focus:ring-[#0b3b72]" />
                        <div class="bg-[#004a9c] text-white text-xs font-bold px-2 py-1 rounded">VNPAY</div>
                        <span class="text-gray-800">Ví điện tử VNPAY</span>
                    </div>

                    <div class="border @(PaymentMethod == 3 ? "border-[#0b3b72]" : "border-gray-200") rounded-md flex items-center gap-3 p-4 cursor-pointer" @onclick="() => PaymentMethod = 3">
                        <input type="radio" name="payment" checked="@(PaymentMethod == 3)" class="w-4 h-4 text-[#0b3b72] focus:ring-[#0b3b72]" />
                        <div class="bg-[#a50064] text-white text-xs font-bold px-2 py-1 rounded">MoMo</div>
                        <span class="text-gray-800">Thanh toán MoMo</span>
                    </div>
                </div>
            </section>
        </div>

        <div class="w-full lg:w-2/5">
            <div class="lg:sticky lg:top-6 space-y-6">
                <div class="flex items-center justify-between border-b pb-2">
                    <div class="flex items-center gap-2">
                        <svg class="w-6 h-6 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 6h12l-2-6M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" /></svg>
                        <h2 class="text-xl font-bold">Giỏ hàng</h2>
                    </div>
                    <a href="/products" class="text-gray-500 underline text-sm">Sản phẩm</a>
                </div>

                @if (ApplicableCartDiscounts.Any())
                {
                    <div class="rounded-md border border-red-200 bg-red-50 p-3 text-red-700">
                        <div class="text-sm font-semibold mb-2">Mã giảm giá áp dụng cho giỏ hàng</div>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var discount in ApplicableCartDiscounts)
                            {
                                var isSelectedVoucher = string.Equals(DiscountCode, discount.MaCode, StringComparison.OrdinalIgnoreCase);
                                <div class="flex items-center gap-2 rounded-full px-3 py-1 @(isSelectedVoucher ? "border-2 border-red-600 bg-red-100" : "border border-red-300 bg-white")">
                                    <span class="text-xs font-semibold text-red-700">@discount.MaCode - @FormatDiscountText(discount)</span>
                                    <button class="rounded-full @(isSelectedVoucher ? "bg-red-800" : "bg-red-600") px-2 py-1 text-[11px] font-bold text-white hover:bg-red-700" @onclick="() => ApplyVoucherCodeAsync(discount.MaCode)">
                                        @(isSelectedVoucher ? "Đã áp dụng" : "Áp dụng")
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (CartModel?.Items?.Any() == true)
                {
                    <div class="space-y-3">
                        @foreach (var item in CartModel.Items)
                        {
                            <div class="flex items-center gap-3 rounded-md border border-gray-200 p-3 bg-white shadow-sm">
                                <div class="h-16 w-16 shrink-0 overflow-hidden rounded-md border border-gray-100 bg-gray-50">
                                    <img src="@GetItemImage(item)" alt="@item.ProductName" class="h-full w-full object-cover object-top" onerror="this.src='product1.jpg';" />
                                </div>
                                <div class="min-w-0 flex-1">
                                    <div class="font-semibold text-sm text-gray-900 truncate">@item.ProductName</div>
                                    <div class="mt-1 flex items-center gap-2 text-xs text-gray-500">
                                        <span class="rounded-full bg-gray-100 px-2 py-0.5">SL: @item.Quantity</span>
                                        <span class="rounded-full bg-blue-50 px-2 py-0.5 text-blue-700">@FormatMoney(GetItemEffectivePrice(item))</span>
                                    </div>
                                    @if (GetItemBestDiscount(item) != null)
                                    {
                                        <div class="mt-1 text-xs text-red-600 font-medium">
                                            Áp dụng: @GetItemBestDiscount(item)!.MaCode - @FormatDiscountText(GetItemBestDiscount(item)!)
                                        </div>
                                    }
                                </div>
                                <div class="flex items-center gap-2">
                                    <button class="h-8 w-8 rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50" @onclick="() => DecreaseItemAsync(item.ProductId)">-</button>
                                    <button class="h-8 w-8 rounded-full border border-gray-300 text-gray-700 hover:bg-gray-50" @onclick="() => IncreaseItemAsync(item.ProductId)">+</button>
                                    <button class="h-8 w-8 rounded-full border border-red-200 text-red-600 hover:bg-red-50" @onclick="() => RemoveItemAsync(item.ProductId)">×</button>
                                </div>
                                <div class="font-semibold text-[#0b3b72] whitespace-nowrap">@FormatMoney(GetItemEffectivePrice(item) * item.Quantity)</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                <div class="flex flex-col items-center justify-center py-8 text-center">
                    <svg class="w-32 h-32 mb-4" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="100" cy="100" r="80" fill="#fef3c7" opacity="0.5" />
                        <path d="M50 80 L150 80 L130 140 L70 140 Z" fill="#f59e0b" stroke="#333" stroke-width="4" stroke-linejoin="round" />
                        <path d="M70 80 L50 40 M130 80 L150 40" stroke="#333" stroke-width="4" stroke-linecap="round" />
                        <path d="M85 105 Q100 120 115 105" fill="none" stroke="#fff" stroke-width="4" stroke-linecap="round" />
                        <circle cx="85" cy="95" r="3" fill="#fff" />
                        <circle cx="115" cy="95" r="3" fill="#fff" />
                    </svg>
                    
                    <h3 class="text-lg font-bold text-gray-900 mb-2">Hiện giỏ hàng của bạn không có sản phẩm nào!</h3>
                    <p class="text-sm text-gray-500 mb-4">Về trang cửa hàng để chọn mua sản phẩm bạn nhé!!</p>
                    <a href="/products" class="border border-gray-800 text-gray-800 font-medium px-6 py-2 rounded hover:bg-gray-50 transition-colors">
                        Mua sắm ngay
                    </a>
                </div>
                }

                <div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Ưu Đãi Dành Cho Bạn</h3>

                    <div class="flex gap-3 mb-4">
                        <input type="text"
                               @bind="DiscountCode"
                               placeholder="Nhập mã giảm giá"
                               class="flex-1 rounded-md border border-gray-300 px-4 py-3 focus:outline-none focus:border-[#0b3b72] focus:ring-1 focus:ring-[#0b3b72]" />
                        <button class="rounded-md bg-[#0b2b73] px-8 py-3 font-bold text-white hover:bg-[#071d4f] transition-colors whitespace-nowrap"
                                @onclick="ApplyVoucherAsync">
                            Áp dụng Voucher
                        </button>
                    </div>

                    @if (ApplicableCartDiscounts.Any())
                    {
                        <div class="overflow-x-auto pb-2">
                            <div class="flex gap-4 min-w-max">
                                @foreach (var discount in ApplicableCartDiscounts)
                                {
                                    var isSelectedVoucher = string.Equals(DiscountCode, discount.MaCode, StringComparison.OrdinalIgnoreCase);
                                    var isBestVoucher = BestApplicableCartDiscount?.MaGG == discount.MaGG;

                                    <div class="relative w-[360px] shrink-0 rounded-xl border bg-white p-4 shadow-sm @(isSelectedVoucher ? "border-[#0b2b73] ring-2 ring-[#0b2b73]" : "border-gray-200")">
                                        @if (isBestVoucher)
                                        {
                                            <div class="absolute right-0 top-0 rounded-bl-lg rounded-tr-xl bg-[#ff4d2d] px-3 py-1 text-[11px] font-extrabold uppercase tracking-wide text-white">
                                                Lựa chọn tốt nhất
                                            </div>
                                        }

                                        <div class="mb-3 pr-28 text-2xl font-extrabold text-gray-900">
                                            @discount.MaCode
                                        </div>

                                        <label class="flex cursor-pointer items-start gap-3">
                                            <input type="radio"
                                                   name="cart-voucher"
                                                   class="mt-1 h-5 w-5 text-[#0b2b73] focus:ring-[#0b2b73]"
                                                   checked="@isSelectedVoucher"
                                                   @onchange="() => ApplyVoucherCodeAsync(discount.MaCode)" />
                                            <div class="space-y-2 text-sm text-gray-700">
                                                <div>Giảm @FormatDiscountText(discount) đơn từ @(discount.GiaTriGiamToiDa.HasValue ? FormatMoney(discount.GiaTriGiamToiDa.Value) : "không giới hạn")</div>
                                                <div>HSD : @discount.HanSuDung.ToString("dd/MM/yyyy")</div>
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-md border border-dashed border-gray-300 bg-gray-50 px-4 py-6 text-sm text-gray-500">
                            Chưa có mã giảm giá hợp lệ cho giỏ hàng hiện tại.
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(checkoutError))
                {
                    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        @checkoutError
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(CheckoutRequirementMessage) && !checkoutError?.Equals(CheckoutRequirementMessage) == true)
                {
                    <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
                        @CheckoutRequirementMessage
                    </div>
                }

                <div class="space-y-3 pt-4 text-gray-700">
                    <div class="flex justify-between items-center">
                        <span>Tạm tính:</span>
                        <div class="text-right">
                            <span class="font-bold text-gray-900">@FormatMoney(TamTinh)</span>
                            <div class="text-xs text-red-500">Tiết kiệm: @FormatMoney(VoucherGiamGia)</div>
                        </div>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Phí vận chuyển:</span>
                        <span class="text-gray-900">Miễn phí</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span>Voucher giảm giá:</span>
                        <span class="text-gray-900">@FormatMoney(VoucherGiamGia)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-sm border-t shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)] z-50">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-4 flex flex-wrap items-center justify-end gap-6">
        <div class="text-right">
            <div class="text-xl font-bold text-[#0b3b72]">@FormatMoney(ThanhTien)</div>
            <div class="text-sm text-gray-600 font-medium">Tiết kiệm: @FormatMoney(VoucherGiamGia)</div>
        </div>
        @if (string.Equals(BuyerId, "guest", StringComparison.OrdinalIgnoreCase))
        {
            <button class="bg-gradient-to-r from-blue-700 to-cyan-600 text-white px-10 py-3 rounded-md font-bold text-lg hover:from-blue-800 hover:to-cyan-700 transition-all shadow-lg" @onclick="GoToLogin">
                Đăng nhập để thanh toán
            </button>
        }
        else
        {
            <button class="bg-[#0b3b72] text-white px-10 py-3 rounded-md font-bold text-lg hover:bg-blue-900 transition-colors" @onclick="CheckoutAsync" disabled="@(CartModel?.Items?.Any() != true || IsGuest)">
                Thanh toán
            </button>
        }
    </div>
</div>

@code {
    private int PaymentMethod = 1;
    private BasketDto? CartModel;
    private string BuyerId = "guest";
    private string HoTen = string.Empty;
    private string SoDienThoai = string.Empty;
    private string DiaChi = string.Empty;
    private string GhiChu = string.Empty;
    private string DiscountCode = string.Empty;
    private Guid? MaGiamGia;
    private decimal VoucherGiamGia;
    private string? checkoutError;
    private bool showFieldErrors;
    private List<MaGiamGiaDto> allDiscounts = new();
    private List<DanhMucDto> allCategories = new();
    private List<LoaiDanhMucDto> allCategoryGroups = new();
    private Dictionary<string, SanPhamDto> productById = new();

    private List<VietnamProvince> Provinces = new();
    private List<VietnamDistrict> Districts = new();
    private List<VietnamWard> Wards = new();
    private string SelectedProvinceCode = string.Empty;
    private string SelectedDistrictCode = string.Empty;
    private string SelectedWardCode = string.Empty;
    private string StreetAddress = string.Empty;

    private decimal TamTinh => CartModel?.Items?.Sum(item => GetItemEffectivePrice(item) * item.Quantity) ?? 0;
    private decimal ThanhTien => Math.Max(TamTinh - VoucherGiamGia, 0);
    private bool IsGuest => string.Equals(BuyerId, "guest", StringComparison.OrdinalIgnoreCase);
    private string CheckoutRequirementMessage
    {
        get
        {
            if (IsGuest)
            {
                return "Bạn cần đăng nhập để thanh toán.";
            }

            var missing = new List<string>();
            if (string.IsNullOrWhiteSpace(HoTen)) missing.Add("Họ và tên");
            if (string.IsNullOrWhiteSpace(SoDienThoai)) missing.Add("Số điện thoại");
            else if (!IsPhoneNumberValid(SoDienThoai)) missing.Add("Số điện thoại đúng định dạng");
            if (string.IsNullOrWhiteSpace(GetFullAddress())) missing.Add("Địa chỉ");

            return missing.Count == 0 ? string.Empty : $"Vui lòng nhập: {string.Join(", ", missing)}.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        BuyerId = await JS.InvokeAsync<string?>("localStorage.getItem", "auth_user_id")
            ?? await JS.InvokeAsync<string?>("localStorage.getItem", "buyer_id")
            ?? "guest";

        if (!IsGuest)
        {
            HoTen = await JS.InvokeAsync<string?>("localStorage.getItem", "auth_ho_ten") ?? string.Empty;
            var userAccountJson = await JS.InvokeAsync<string?>("localStorage.getItem", "user_account");
            if (!string.IsNullOrWhiteSpace(userAccountJson))
            {
                var account = System.Text.Json.JsonSerializer.Deserialize<TaiKhoan>(userAccountJson);
                if (account != null)
                {
                    SoDienThoai = account.SoDienThoai ?? string.Empty;
                    DiaChi = account.DiaChi ?? string.Empty;
                    if (string.IsNullOrWhiteSpace(HoTen))
                    {
                        HoTen = account.HoTen ?? string.Empty;
                    }
                }
            }
        }

        CartModel = await BasketService.GetBasketAsync(BuyerId) ?? new BasketDto { UserName = BuyerId };
        allDiscounts = (await DiscountService.GetDiscountsAsync()).ToList();
        allCategories = (await CategoryService.GetAllAsync()).ToList();
        allCategoryGroups = (await CategoryService.GetAllLoaiDanhMucAsync()).ToList();
        productById = (await ProductService.GetAllAsync()).ToDictionary(x => x.MaSP.ToString(), x => x);
        DiscountCode = await JS.InvokeAsync<string?>("localStorage.getItem", "pending_discount_code") ?? string.Empty;
        await LoadVietnamProvincesAsync();

        if (CartModel?.Items?.Any() == true)
        {
            foreach (var item in CartModel.Items)
            {
                item.Price = GetItemEffectivePrice(item);
            }

            await BasketService.UpdateBasketAsync(CartModel);
        }
    }

    private async Task LoadVietnamProvincesAsync()
    {
        try
        {
            Provinces = await JS.InvokeAsync<List<VietnamProvince>>("vietnamProvincesData.getProvinces");
        }
        catch
        {
            Provinces = new List<VietnamProvince>();
        }
    }

    private async Task OnProvinceChangedAsync(ChangeEventArgs e)
    {
        SelectedProvinceCode = e.Value?.ToString() ?? string.Empty;
        SelectedDistrictCode = string.Empty;
        SelectedWardCode = string.Empty;
        Districts = string.IsNullOrWhiteSpace(SelectedProvinceCode)
            ? new List<VietnamDistrict>()
            : await JS.InvokeAsync<List<VietnamDistrict>>("vietnamProvincesData.getDistricts", SelectedProvinceCode);
        Wards = new List<VietnamWard>();
    }

    private async Task OnDistrictChangedAsync(ChangeEventArgs e)
    {
        SelectedDistrictCode = e.Value?.ToString() ?? string.Empty;
        SelectedWardCode = string.Empty;
        Wards = string.IsNullOrWhiteSpace(SelectedDistrictCode)
            ? new List<VietnamWard>()
            : await JS.InvokeAsync<List<VietnamWard>>("vietnamProvincesData.getWards", SelectedDistrictCode);
    }

    private void OnWardChanged(ChangeEventArgs e)
    {
        SelectedWardCode = e.Value?.ToString() ?? string.Empty;
    }

    private async Task ApplyVoucherAsync()
    {
        if (string.IsNullOrWhiteSpace(DiscountCode))
        {
            return;
        }

        var voucher = await DiscountService.GetDiscountByCodeAsync(DiscountCode);
        if (voucher == null)
        {
            await JS.InvokeVoidAsync("alert", "Mã giảm giá không hợp lệ");
            return;
        }

        if (CartModel?.Items?.Any() != true)
        {
            return;
        }

        if (!IsVoucherApplicableToCart(voucher))
        {
            await JS.InvokeVoidAsync("alert", "Mã giảm giá không áp dụng cho sản phẩm trong giỏ hàng");
            return;
        }

        MaGiamGia = voucher.MaGG;
        VoucherGiamGia = CalculateCartDiscount(voucher);
    }

    private async Task ApplyVoucherCodeAsync(string code)
    {
        DiscountCode = code;
        await JS.InvokeVoidAsync("localStorage.setItem", "pending_discount_code", code);
        await ApplyVoucherAsync();
    }

    private IEnumerable<MaGiamGiaDto> ApplicableCartDiscounts => CartModel?.Items?.Any() == true
        ? DiscountPricingHelper.GetApplicableDiscountsForCart(CartModel.Items, productById, allCategoryGroups, allCategories, allDiscounts)
        : Enumerable.Empty<MaGiamGiaDto>();

    private MaGiamGiaDto? BestApplicableCartDiscount => ApplicableCartDiscounts.FirstOrDefault();

    private async Task CheckoutAsync()
    {
        checkoutError = null;
        showFieldErrors = true;

        if (CartModel?.Items?.Any() != true)
        {
            return;
        }

        var fullAddress = GetFullAddress();
        if (IsGuest)
        {
            await JS.InvokeVoidAsync("alert", "Bạn cần đăng nhập để thanh toán");
            Navigation.NavigateTo("/account/signin?returnUrl=/cart");
            return;
        }

        if (string.IsNullOrWhiteSpace(HoTen) || string.IsNullOrWhiteSpace(SoDienThoai) || string.IsNullOrWhiteSpace(fullAddress))
        {
            checkoutError = CheckoutRequirementMessage;
            return;
        }

        if (!IsPhoneNumberValid(SoDienThoai))
        {
            checkoutError = CheckoutRequirementMessage;
            return;
        }

        var request = new CreateDonHangRequest
        {
            MaTK = Guid.TryParse(BuyerId, out var userId) ? userId : Guid.Empty,
            HoTen = HoTen,
            SoDienThoai = SoDienThoai,
            MaGG = MaGiamGia,
            DiaChiGiaoHang = fullAddress,
            ChiTietDonHangs = CartModel.Items.Select(x => new CreateChiTietDonHangRequest
            {
                MaCTSP = Guid.TryParse(x.ProductId, out var ctsp) ? ctsp : Guid.NewGuid(),
                TenSP_LuuTru = x.ProductName,
                Gia_LuuTru = x.Price,
                SoLuong = x.Quantity,
                Anh_LuuTru = x.ImageUrl
            }).ToList()
        };

        var order = await OrderService.CreateOrderAsync(request);
        if (order == null)
        {
            await JS.InvokeVoidAsync("alert", "Đặt hàng thất bại");
            return;
        }

        await BasketService.DeleteBasketAsync(BuyerId);
        await JS.InvokeVoidAsync("alert", "Đặt hàng thành công");
        Navigation.NavigateTo("/account/orders");
    }

    private async Task IncreaseItemAsync(string productId)
    {
        var item = CartModel?.Items.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        item.Quantity++;
        await SaveCartAsync();
    }

    private async Task DecreaseItemAsync(string productId)
    {
        var item = CartModel?.Items.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        if (item.Quantity > 1)
        {
            item.Quantity--;
            await SaveCartAsync();
            return;
        }

        await RemoveItemAsync(productId);
    }

    private async Task RemoveItemAsync(string productId)
    {
        if (CartModel?.Items == null) return;

        var item = CartModel.Items.FirstOrDefault(x => x.ProductId == productId);
        if (item == null) return;

        CartModel.Items.Remove(item);
        await SaveCartAsync();
    }

    private async Task SaveCartAsync()
    {
        if (CartModel == null) return;

        if (CartModel.Items.Count == 0)
        {
            await BasketService.DeleteBasketAsync(BuyerId);
            StateHasChanged();
            return;
        }

        CartModel.UserName = BuyerId;
        await BasketService.UpdateBasketAsync(CartModel);
        StateHasChanged();
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/account/signin?returnUrl=/cart");
    }

    private static string GetItemImage(BasketItemDto item)
    {
        return string.IsNullOrWhiteSpace(item.ImageUrl) ? "product1.jpg" : item.ImageUrl;
    }

    private decimal GetItemEffectivePrice(BasketItemDto item)
    {
        if (!Guid.TryParse(item.ProductId, out var productId))
        {
            return item.Price;
        }

        var product = productById.Values.FirstOrDefault(x => x.MaSP == productId);
        if (product == null)
        {
            return item.Price;
        }

        var discount = DiscountPricingHelper.GetBestApplicableDiscount(product, item.Price, allCategoryGroups, allCategories, allDiscounts);
        return DiscountPricingHelper.GetFinalPrice(discount, item.Price);
    }

    private MaGiamGiaDto? GetItemBestDiscount(BasketItemDto item)
    {
        if (!Guid.TryParse(item.ProductId, out var productId))
        {
            return null;
        }

        var product = productById.Values.FirstOrDefault(x => x.MaSP == productId);
        if (product == null)
        {
            return null;
        }

        return DiscountPricingHelper.GetBestApplicableDiscount(product, item.Price, allCategoryGroups, allCategories, allDiscounts);
    }

    private decimal CalculateCartDiscount(MaGiamGiaDto discount)
    {
        if (CartModel?.Items?.Any() != true)
        {
            return 0;
        }

        return CartModel.Items.Sum(item =>
        {
            if (!Guid.TryParse(item.ProductId, out var productId))
            {
                return 0m;
            }

            var product = productById.Values.FirstOrDefault(x => x.MaSP == productId);
            if (product == null)
            {
                return 0m;
            }

            return DiscountPricingHelper.IsApplicable(discount, product, allCategories.FirstOrDefault(c => c.MaDM == product.MaDM)?.MaLDM)
                ? DiscountPricingHelper.GetDiscountAmount(discount, item.Price) * item.Quantity
                : 0m;
        });
    }

    private bool IsVoucherApplicableToCart(MaGiamGiaDto discount)
    {
        if (CartModel?.Items?.Any() != true)
        {
            return false;
        }

        foreach (var item in CartModel.Items)
        {
            if (!Guid.TryParse(item.ProductId, out var productId))
            {
                continue;
            }

            var product = productById.Values.FirstOrDefault(x => x.MaSP == productId);
            if (product == null)
            {
                continue;
            }

            var currentCategory = allCategories.FirstOrDefault(c => c.MaDM == product.MaDM);
            if (DiscountPricingHelper.IsApplicable(discount, product, currentCategory?.MaLDM))
            {
                return true;
            }
        }

        return false;
    }

    private static string FormatDiscountText(MaGiamGiaDto discount)
        => discount.Loai == "PhanTram"
            ? discount.SoTien.ToString("0") + "%"
            : discount.SoTien.ToString("N0") + "đ";

    private static string FormatMoney(decimal money) => $"{money:n0}đ";

    private bool ShowFieldError(string? value) => showFieldErrors && string.IsNullOrWhiteSpace(value);

    private bool ShowPhoneError => showFieldErrors && !IsPhoneNumberValid(SoDienThoai);

    private static bool IsPhoneNumberValid(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone))
        {
            return false;
        }

        return System.Text.RegularExpressions.Regex.IsMatch(phone.Trim(), @"^(0|\+84)(3|5|7|8|9)[0-9]{8}$");
    }

    private string GetFieldClass(string? value)
    {
        return ShowFieldError(value)
            ? "w-full rounded-md px-4 py-2.5 border border-red-400 focus:outline-none focus:ring-1 focus:border-red-500 focus:ring-red-200"
            : "w-full rounded-md px-4 py-2.5 border border-gray-300 focus:outline-none focus:ring-1 focus:border-blue-500 focus:ring-blue-500";
    }

    private string GetFullAddress()
    {
        var parts = new[]
        {
            StreetAddress,
            Wards.FirstOrDefault(x => x.Code == SelectedWardCode)?.Name,
            Districts.FirstOrDefault(x => x.Code == SelectedDistrictCode)?.Name,
            Provinces.FirstOrDefault(x => x.Code == SelectedProvinceCode)?.Name
        }.Where(x => !string.IsNullOrWhiteSpace(x));

        return string.Join(", ", parts);
    }

