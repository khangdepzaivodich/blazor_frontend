                                    <li><a href="/category/f641efa0-571c-4876-92d1-19c985968d39/Bán chạy" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Bán chạy</a></li>
                                    <li><a href="/category/f641efa0-571c-4876-92d1-19c985968d39/Khuyến mãi" class="block border-l-2 border-transparent px-3 py-2 font-semibold text-red-500! transition-all duration-200 hover:border-red-500 hover:bg-red-50! hover:text-red-600!">Sale</a></li>
                                </ul>
                            </div>

                            <div class="px-6">
                                <a href="/category/f641efa0-571c-4876-92d1-19c985968d39/Áo">
                                    <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-gray-900 hover:text-blue-600 transition-colors">Áo</h3>
                                </a>
                                <ul class="space-y-1 text-[15px] font-medium text-gray-500">
                                    <li><a href="/subcategory/60a3c1be-ae8d-4720-85e7-6cbcce09be84/Áo thun" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Thun</a></li>
                                    <li><a href="/subcategory/bb656af1-534e-4c73-8aba-1dbf8c2c449d/Áo sơ mi" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Sơ mi</a></li>
                                    <li><a href="/subcategory/deadc13c-8ff0-4ae9-8df9-ea81b00a8e1f/Áo polo" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Polo</a></li>
                                </ul>
                            </div>

                            <div class="px-6">
                                <a href="/category/4c418a3e-1769-4f39-8379-f39db79ec50f/Quần">
                                    <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-gray-900 hover:text-blue-600 transition-colors">Quần</h3>
                                </a>
                                <ul class="space-y-1 text-[15px] font-medium text-gray-500">
                                    <li><a href="/subcategory/dcf16b99-5241-4acd-8106-a3372b76f729/Quần Jean" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Jean</a></li>
                                    <li><a href="/subcategory/9ab1c2df-e37e-4c83-9b38-1cd37896d696/Quần Tây" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Quần Tây</a></li>
                                    <li><a href="/subcategory/c1784ca7-abfe-4c46-9c0c-f1ad40363a0d/Quần Short" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Short</a></li>
                                </ul>
                            </div>

                            <div class="px-6">
                                <a href="/category/865167ea-cdbc-41ed-a282-c28353cf50e3/Phụ kiện">
                                    <h3 class="mb-4 text-sm font-bold uppercase tracking-wider text-gray-900 hover:text-blue-600 transition-colors">Phụ kiện</h3>
                                </a>
                                <ul class="space-y-1 text-[15px] font-medium text-gray-500">
                                    <li><a href="/category/865167ea-cdbc-41ed-a282-c28353cf50e3/Thắt lưng" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Thắt lưng</a></li>
                                    <li><a href="/category/aaee47ce-87f2-4875-93fb-07df6bd4b77b/Khác" class="block border-l-2 border-transparent px-3 py-2 transition-all duration-200 hover:border-gray-900 hover:bg-gray-50 hover:text-gray-900">Khác</a></li>
                                </ul>
                            </div>

                            <div class="pl-6 space-y-3">
                                <a href="/products/summer" class="group/card block overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                                    <img src="hero.png" class="h-28 w-full object-cover transition duration-300 group-hover/card:scale-110" alt="Summer collection" />
                                    <div class="p-3 text-sm font-bold text-gray-900">Summer</div>
                                </a>
                                <a href="/products/sport" class="group/card block overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                                    <img src="product1.jpg" class="h-28 w-full object-cover transition duration-300 group-hover/card:scale-110" alt="Sport collection" />
                                    <div class="p-3 text-sm font-bold text-gray-900">Sport</div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <a href="/products/new" class="nav-link py-3">Hàng mới</a>
            <a href="/products/best-seller" class="nav-link py-3">Bán chạy</a>
            <a href="/products/denim" class="nav-link py-3">DENIM</a>
            <a href="/products/outlet" class="nav-link py-3 text-red-500! hover:text-red-600! font-semibold">OUTLET</a>

            <div class="relative flex items-center ml-4">
                <div class="group flex items-center bg-gray-50 rounded-full px-4 py-2 border border-transparent focus-within:border-gray-200 focus-within:bg-white transition-all w-48 focus-within:w-64">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" 
                           @bind="headerSearchTerm"
                           @bind:event="oninput"
                           @onkeyup="HandleHeaderSearch"
                           placeholder="Tìm kiếm..." 
                           class="ml-2 bg-transparent border-none text-sm w-full focus:ring-0 placeholder-gray-400 font-medium" />
                </div>
            </div>
        </nav>

        <!-- RIGHT -->
        <div class="flex items-center gap-1 sm:gap-2">
            <!-- ACCOUNT -->
            <div class="relative">
                <button type="button"
                        class="header-icon-btn-light inline-flex h-10 w-10 items-center justify-center"
                        @onclick="ToggleAccount"
                        aria-label="Account">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21a8 8 0 0 0-16 0" />
                        <circle cx="12" cy="8" r="4" />
                    </svg>
                </button>

                <div class="@(_accountOpen ? "block" : "hidden") account-dropdown-light absolute right-0 mt-3 w-56 overflow-hidden rounded-2xl animate-fade-in-down z-50">
                    @if (_isLoggedIn)
                    {
                        <div class="border-b border-gray-100 px-4 py-3">
                            <div class="text-sm font-semibold text-gray-900">Tài khoản</div>
                            <div class="text-xs text-gray-500">Quản lý hồ sơ và đơn hàng</div>
                        </div>
                        <a href="/account/profile" class="block px-4 py-3 text-sm transition" @onclick="CloseAll">Profile</a>
                        <a href="/account/orders" class="block px-4 py-3 text-sm transition" @onclick="CloseAll">Đơn hàng của tôi</a>
                        <div class="border-t border-gray-100"></div>
                        <button class="block w-full px-4 py-3 text-left text-sm text-red-600 transition hover:bg-red-50" @onclick="LogoutAsync">Đăng xuất</button>
                    }
                    else
                    {
                        <div class="p-4">
                            <a href="/account/login" class="block w-full rounded-xl bg-gray-900 py-2.5 text-center text-sm font-bold text-white transition hover:bg-black" @onclick="CloseAll">Đăng nhập</a>
                            <a href="/account/register" class="mt-2 block w-full rounded-xl border border-gray-200 py-2.5 text-center text-sm font-bold text-gray-900 transition hover:bg-gray-50" @onclick="CloseAll">Đăng ký</a>
                        </div>
                    }
                </div>
            </div>

            <!-- CART -->
            <a href="/cart" class="header-icon-btn-light relative inline-flex h-10 w-10 items-center justify-center" aria-label="Giỏ hàng">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                    <path d="M3 6h18" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                @if (CartCount > 0)
                {
                    <span class="absolute right-1 top-1 flex h-4 w-4 items-center justify-center rounded-full bg-blue-600 text-[10px] font-bold text-white">@CartCount</span>
                }
            </a>
        </div>
    </div>
</header>