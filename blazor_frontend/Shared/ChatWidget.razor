@inject IJSRuntime JS
@using System.Text.Json
@using blazor_frontend.Models
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

@if (isOpen)
{
    <div class="fixed bottom-20 right-6 w-80 h-96 bg-white border border-gray-200 rounded-lg shadow-xl flex flex-col z-50">
        <!-- Chat header -->
        <div class="bg-blue-600 text-white p-3 rounded-t-lg flex justify-between items-center group relative">
            <h3 class="font-bold">Chat trực tuyến</h3>
            <div class="flex gap-2 items-center">
                <a href="/account/messages" class="text-white/80 hover:text-white" title="Mở trang tin nhắn">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
                <button @onclick="ToggleChat" class="text-white/80 hover:text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>
        <!-- Chat messages -->
        <div class="flex-1 p-3 overflow-y-auto bg-gray-50 flex flex-col gap-2 relative">
            @if (messages != null && messages.Any())
            {
                @foreach (var msg in messages)
                {
                    <div class="@(msg.IsMine ? "self-end bg-blue-600 text-white" : "self-start bg-blue-100 text-blue-900") p-2 rounded-lg max-w-[80%] text-sm">
                        @msg.Text
                    </div>
                }
            }
        </div>
        <!-- Chat input -->
        <div class="p-3 border-t flex gap-2">
            <input type="text" @bind="newMessage" @onkeyup="HandleKeyUp" class="flex-1 border rounded-full px-3 py-1.5 focus:outline-none focus:border-blue-500 text-sm" placeholder="Nhập tin nhắn..." />
            <button @onclick="SendMessage" class="bg-blue-600 text-white p-1.5 rounded-full hover:bg-blue-700 w-8 h-8 flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
        </div>
    </div>
}

<button @onclick="ToggleChat" class="fixed bottom-6 right-6 w-14 h-14 bg-blue-600 rounded-full shadow-lg flex items-center justify-center text-white z-50 hover:bg-blue-700 transition transform hover:scale-110">
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
</button>

@code {
    private bool isOpen = false;
    private string currentSessionId = "";
    private string guestId = ""; // UUID định danh thiết bị
    private string newMessage = "";
    private List<ChatMessage> messages = new();

    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        // 1. Phân biệt Guest hay User
        guestId = await JS.InvokeAsync<string>("localStorage.getItem", "chat_guest_id");
        if (string.IsNullOrEmpty(guestId))
        {
            guestId = $"GUEST_{Guid.NewGuid().ToString().Substring(0,8)}";
            await JS.InvokeVoidAsync("localStorage.setItem", "chat_guest_id", guestId);
        }

        // 2. Chờ kết nối SignalR...
        hubConnection = new HubConnectionBuilder()
            .WithUrl("http://localhost:5041/chat-hub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<TinNhanDto>("ReceiveNewMessage", async (tinNhan) =>
        {
            // Chỉ thêm tin nhắn nếu người gửi không phải là khách này (tránh duplicate tin tự gửi)
            if (tinNhan.SenderType != "GUEST")
            {
                messages.Add(new ChatMessage { Text = tinNhan.NoiDung, IsMine = false, Timestamp = tinNhan.ThoiGianGui });
                await SaveMessages();
                await InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi khi kết nối SignalR Backend Chat: " + ex.Message);
        }

        // 3. Xử lý Session ID
        var session = await JS.InvokeAsync<string>("localStorage.getItem", "chat_session_id");

        if (string.IsNullOrEmpty(session))
        {
            // Gọi Backend tạo Phiên và trả về maPhien (Guid)
            currentSessionId = await hubConnection.InvokeAsync<string>("CreateNewChatSession", guestId, "GUEST");
            await JS.InvokeVoidAsync("localStorage.setItem", "chat_session_id", currentSessionId);

            // Gửi tin nhắn chào mừng
            messages.Add(new ChatMessage { Text = "Chào bạn! Chúng tôi có thể giúp gì cho bạn hôm nay?", IsMine = false, Timestamp = DateTime.Now });
            await SaveMessages();
        }
        else
        {
            // tải phiên chat cũ từ localStorage
            currentSessionId = session;
            var history = await JS.InvokeAsync<string>("localStorage.getItem", $"chat_history_{currentSessionId}");

            if (!string.IsNullOrEmpty(history))
            {
                try { messages = JsonSerializer.Deserialize<List<ChatMessage>>(history) ?? new(); }
                catch { messages = new(); }
            }

            // Gọi Hub để join vào room cũ
            await hubConnection.SendAsync("JoinChatSession", currentSessionId);
        }
    }

    private void ToggleChat()
    {
        isOpen = !isOpen;
    }

    private async Task HandleKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newMessage))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessage)) return;

        var textToSend = newMessage.Trim();
        newMessage = "";

        // Hiện tin nhắn
        messages.Add(new ChatMessage { Text = textToSend, IsMine = true, Timestamp = DateTime.Now });
        await SaveMessages();

        // Đẩy xuống Backend qua SignalR
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            var tn = new TinNhanDto
            {
                MaPhien = Guid.Parse(currentSessionId),
                SenderType = "GUEST",
                NoiDung = textToSend,
                TrangThai = "sent"
            };

            await hubConnection.SendAsync("SendMessage", tn);
        }
    }

    private async Task SaveMessages()
    {
        var json = JsonSerializer.Serialize(messages);
        await JS.InvokeVoidAsync("localStorage.setItem", $"chat_history_{currentSessionId}", json);
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // --- CÁC MODELS MAP TỪ API ---
    public class TinNhanDto
    {
        public Guid MaPhien { get; set; }
        public string SenderType { get; set; } = string.Empty;
        public string NoiDung { get; set; } = string.Empty;
        public DateTime ThoiGianGui { get; set; } = DateTime.UtcNow;
        public string TrangThai { get; set; } = string.Empty;
    }

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsMine { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
