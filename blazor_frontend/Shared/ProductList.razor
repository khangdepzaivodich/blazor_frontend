@using Microsoft.AspNetCore.Components
@using System.Collections.Generic
@using System.Linq

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
    @if (Items != null)
    {
        @foreach (var p in Items)
        {
            <ProductCard ImagePath="@p.ImagePath"
                         Title="@p.Title"
                         Price="@p.Price"
                         BadgeText="@p.BadgeText"
                         Colors="@p.Colors"
                         ProductId="@p.Id"
                         ShowActions="@ShowActions" />
        }
    }
</div>

@code {
    [Parameter] public IEnumerable<ProductDto> Items { get; set; } = Enumerable.Empty<ProductDto>();
    [Parameter] public bool ShowActions { get; set; } = true;

    public record ProductDto(int Id, string ImagePath, string Title, string Price, string BadgeText, string[] Colors);
}